---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/strings.ts';

interface Props {
  title?: string;
  description?: string;
  lang: Lang;
  permalink?: string;
  bodyClass?: string;
  featuredImage?: string;
  translations?: Partial<Record<Lang, string>>;
}

const {
  title = 'Festival ADAR',
  description = 'Para el desarrollo de las artes en el medio rural',
  lang,
  permalink = '',
  bodyClass = '',
  featuredImage,
  translations = {},
} = Astro.props;

const fullTitle = title === 'Festival ADAR'
  ? `Festival ADAR – ${description}`
  : `${title} – Festival ADAR`;
const ogImage =
  featuredImage || 'https://creartbox-media-cdn.b-cdn.net/adarimages/adar25fx30/DSC01841.jpg';
---

<!doctype html>
<html lang={lang === 'ast' ? 'ast' : lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`https://festivaladar.com${permalink}`} />
    {Object.entries(translations).map(([l, url]) => (
      <link rel="alternate" hreflang={l} href={`https://festivaladar.com${url}`} />
    ))}

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={`https://festivaladar.com${permalink}`} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/png" href="/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wdth,wght@12..96,75..100,200..800&family=EB+Garamond:ital,wght@0,400..600;1,400..600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class={`page ${bodyClass}`}>
    <div id="page" class="site">
      <a class="skip-link screen-reader-text" href="#content">Skip to content</a>
      <Header lang={lang} currentPath={permalink} translations={translations} />
      <div id="content" class="site-content">
        <main id="main" class="site-main" role="main">
          <slot />
        </main>
      </div>
      <Footer lang={lang} />
    </div>
    <script is:inline>
      (function () {
        // Pages that begin with a .page-hero or .hm-hero get a floating
        // header (transparent over the image). When the user scrolls
        // past the hero, swap to the solid paper header.
        var firstSection = document.querySelector('main .page-hero, main .hm-hero');
        if (!firstSection) return;
        document.body.classList.add('has-floating-header');
        function update() {
          var rect = firstSection.getBoundingClientRect();
          var threshold = rect.height * 0.6;
          if (rect.bottom < threshold) {
            document.body.classList.add('is-scrolled');
          } else {
            document.body.classList.remove('is-scrolled');
          }
        }
        update();
        window.addEventListener('scroll', update, { passive: true });
        window.addEventListener('resize', update);
      })();
    </script>
    <script is:inline>
      (function () {
        // Smart header para páginas SIN hero flotante: position:sticky se
        // rompe por un overflow ancestro y el header desaparecía al hacer
        // scroll sin volver nunca. Lo pasamos a fijo (compensando su altura
        // con padding-top), se oculta al bajar y REAPARECE en cuanto el
        // usuario hace scroll hacia arriba.
        var body = document.body;
        if (body.classList.contains('has-floating-header')) return;
        var header = document.getElementById('masthead');
        if (!header) return;
        function setH() {
          body.style.setProperty('--adar-hdr-h', header.offsetHeight + 'px');
        }
        setH();
        body.classList.add('adar-header-fixed');
        window.addEventListener('resize', setH);
        var lastY = window.scrollY;
        window.addEventListener('scroll', function () {
          var y = Math.max(0, window.scrollY);
          var dy = y - lastY;
          if (Math.abs(dy) < 6) return;
          var keep =
            y <= header.offsetHeight ||
            dy < 0 ||
            body.classList.contains('adar-nav-open') ||
            document.querySelector('.cd-lang-dd[open]');
          body.classList.toggle('adar-header-hidden', !keep);
          lastY = y;
        }, { passive: true });
      })();
    </script>
  </body>
</html>
