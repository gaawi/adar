// Build a unique artist list (preserving instrument labels from first occurrence)
const seen = new Set<string>();
const ARTISTS = EVENTS.flatMap((e) => e.artists).filter((a) => {
  if (seen.has(a.name)) return false;
  seen.add(a.name);
  return true;
});

const MAP_HREFS: Record<Lang, string> = {
  es: '/es/mapa-de-acciones/',
  en: '/en/map-of-actions/',
  ast: '/ast/mapa-dacciones/',
};

const PRESS_HREF: Record<Lang, string> = {
  es:  '/es/nota-de-prensa-adar-2026/',
  en:  '/en/press-release-adar-2026/',
  ast: '/ast/nota-de-prensa-adar-2026/',
};

const POSTER_BG = 'https://creartbox-archive.b-cdn.net/adarimages/posters/2026.jpg';
---

<BaseLayout
  title={COPY.title}
  lang={lang}
  permalink={`/${lang}/programa-2026/`}
  featuredImage={POSTER_BG}
  bodyClass="vi26-body"
  translations={{
    es: '/es/programa-2026/',
    en: '/en/programa-2026/',
    ast: '/ast/programa-2026/',
  }}
>

<div class="vi26">

  <!-- HERO · anillo amarillo · "Festival ADAR 2026" gigante -->
  <section class="prog-current vi26-hero-ring">
    <svg class="prog-current-ring" viewBox="0 0 800 800" aria-hidden="true">
      <circle cx="400" cy="400" r="380" fill="none" stroke="currentColor" stroke-width="1" />
      <circle cx="400" cy="400" r="320" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="2 6" />
      <circle cx="400" cy="400" r="260" fill="none" stroke="currentColor" stroke-width="1" />
    </svg>
    <div class="prog-current-body">
      <span class="prog-current-pill">{COPY.poster_kicker}</span>
      <h1 class="vi26-hero-title">{COPY.hero_h}</h1>
      <p class="vi26-hero-tag">{COPY.hero_tag}</p>
      <div class="prog-current-ctas">
        <a class="prog-current-cta" href="#program">
          <span class="prog-arr">↓</span>
          {COPY.cta_program}
        </a>
        <a class="prog-current-cta prog-current-cta-ghost" href={PRESS_HREF[lang]}>
          <span class="prog-arr">→</span>
          {COPY.cta_press}
        </a>
      </div>
    </div>
  </section>

  <!-- PROGRAM -->
  <section class="vi26-venues" id="program">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.nights_n}</span>
      <h2 class="vi26-section-h">{COPY.nights_h}</h2>
      <p class="vi26-section-sub">{COPY.nights_sub}</p>
    </header>

    <ol class="vi26-event-list">
      {EVENTS.filter((e) => !e.rest).map((e) => {
        const kind = e.subtitle ? e.subtitle.split('·')[0].trim() : '';
        const isLongProgram = e.pieces.length > 8;
        return (
          <li class="vi26-event" id={`event-${e.n}`}>
            <aside class="vi26-aside">
              {e.photo ? (
                <figure class="vi26-cover">
                  <img src={e.photo} alt={e.venue} loading="lazy" />
                </figure>
              ) : (
                <div class="vi26-cover vi26-cover-empty">
                  <span class="mono">{COPY.soon}</span>
                </div>
              )}

              <div class="vi26-aside-info">
                <p class="vi26-aside-n mono">N° {e.n}</p>

                <dl class="vi26-aside-facts">
                  {kind && (<><dt class="mono">{COPY.th_kind}</dt><dd>{kind}</dd></>)}
                  <dt class="mono">{COPY.venue_h}</dt>
                  <dd>
                    <span class="vi26-aside-venue">{e.venue}</span>
                    {e.address && <span class="vi26-aside-address mono">{e.address}</span>}
                  </dd>
                  {e.capacity && (
                    <><dt class="mono">{COPY.capacity_label}</dt><dd>{e.capacity} {COPY.seats_label}</dd></>
                  )}
                </dl>

                {e.venueNote && (
                  <p class="vi26-aside-note mono">{e.venueNote}</p>
                )}

                <div class="vi26-event-cta">
                  {e.eventbrite ? (
                    <a class="vi26-rsvp" href={e.eventbrite} target="_blank" rel="noopener">
                      <span class="vi26-arr">→</span> {COPY.rsvp}
                    </a>
                  ) : (
                    <span class="vi26-rsvp is-soon">{COPY.seats_soon}</span>
                  )}
                  <p class="vi26-rsvp-note mono">{COPY.free_note}</p>
                </div>
              </div>
            </aside>

            <div class="vi26-content">
              <header class="vi26-event-place">
                <div class="vi26-event-place-main">
                  <span class="vi26-event-place-venue">{e.venue}</span>
                  <span class="vi26-event-place-sub mono">
                    <span class="vi26-event-place-addr">{e.address || e.municipality}</span>
                    {e.mapUrl && (
                      <a class="vi26-event-place-map"
                         href={e.mapUrl}
                         target="_blank" rel="noopener">
                        Ver mapa <span aria-hidden="true">↗</span>
                      </a>
                    )}
                  </span>
                </div>
                <div class="vi26-event-place-when">
                  <span class="vi26-event-place-dow mono">{e.dow}</span>
                  <span class="vi26-event-place-date">{e.fullDate}</span>
                </div>
              </header>
              <h3 class="vi26-event-title">{e.title}</h3>
              {e.subtitle && <p class="vi26-event-sub mono">↳ {e.subtitle}</p>}

              {e.description && <p class="vi26-event-desc">{e.description}</p>}

              {e.pieces.length > 0 ? (
                <div class="vi26-program-wrap">
                  <p class="vi26-block-label mono">{COPY.program_h}{e.programName ? ` · ${e.programName}` : ''}</p>
                  <ol class={`vi26-program ${isLongProgram ? 'is-multi' : ''}`}>
                    {e.pieces.map((p) => (
                      <li>
                        <span class="vi26-program-composer">{p.composer}{p.years ? <span class="vi26-program-years mono"> {p.years}</span> : null}</span>
                        <span class="vi26-program-piece"> · <em>{p.piece}</em></span>
                        {p.duration && <span class="vi26-program-dur mono"> [{p.duration}]</span>}
                      </li>
                    ))}
                  </ol>
                  {e.totalDuration && <p class="vi26-program-total mono">{COPY.duration_total} · {e.totalDuration}</p>}
                </div>
              ) : e.programNote ? (
                <div class="vi26-program-wrap">
                  <p class="vi26-block-label mono">{COPY.program_h}</p>
                  <p class="vi26-program-note">{e.programNote}</p>
                </div>
              ) : null}

              <div class="vi26-artists-wrap">
                <p class="vi26-block-label mono">{COPY.artists_h}</p>
                <ul class="vi26-artist-line">
                  {e.artists.map((a) => (
                    <li>
                      <span class="vi26-artist-l-name">{a.name}</span>
                      <span class="vi26-artist-l-role mono"> · {a.role}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </li>
        );
      })}
    </ol>
  </section>

  <!-- CARTEL -->
  <section class="vi26-cartel">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.cartel_n}</span>
      <h2 class="vi26-section-h">{COPY.cartel_h}</h2>
      <p class="vi26-section-sub">{COPY.cartel_sub}</p>
    </header>

    <ul class="vi26-cartel-list">
      {ARTISTS.map((a) => (
        <li class="vi26-cartel-row">
          <span class="vi26-cartel-name">{a.name}</span>
          <span class="vi26-cartel-role mono">{a.role}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- CALENDAR -->
  <section class="vi26-calendar">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.cal_n}</span>
      <h2 class="vi26-section-h">{COPY.cal_h}</h2>
      <p class="vi26-section-sub">{COPY.cal_sub}</p>
    </header>

    <div class="vi26-table-wrap">
      <table class="vi26-table">
        <thead>
          <tr>
            <th class="mono">{COPY.th_n}</th>
            <th class="mono">{COPY.th_date}</th>
            <th class="mono">{COPY.th_kind}</th>
            <th class="mono">{COPY.th_venue}</th>
            <th class="mono">{COPY.th_artists}</th>
            <th class="mono">{COPY.th_rsvp}</th>
          </tr>
        </thead>
        <tbody>
          {EVENTS.map((e) => e.rest ? (
            <tr class="is-tbc is-rest">
              <td class="mono vi26-td-n">—</td>
              <td class="mono"><span class="vi26-dow">{e.dow}</span> {e.fullDate}</td>
              <td class="mono vi26-td-kind">{COPY.rest}</td>
              <td class="vi26-td-venue">—</td>
              <td class="mono">—</td>
              <td>—</td>
            </tr>
          ) : (
            <tr class={e.tbc ? 'is-tbc' : ''}>
              <td class="mono vi26-td-n">{e.n}</td>
              <td class="mono"><span class="vi26-dow">{e.dow}</span> {e.fullDate}</td>
              <td class="mono vi26-td-kind">{e.subtitle?.split('·')[0]?.trim() || e.title}</td>
              <td class="vi26-td-venue">{e.venue}{e.municipality ? <span class="mono vi26-td-muni"> · {e.municipality}</span> : null}</td>
              <td class="mono">{e.artists.map((a) => a.name.split(' ')[0]).join(' · ')}</td>
              <td>
                {e.eventbrite ? (
                  <a class="vi26-rsvp-mini" href={e.eventbrite} target="_blank" rel="noopener">{COPY.rsvp} ↗</a>
                ) : (
                  <span class="vi26-rsvp-mini vi26-rsvp-soon mono">{COPY.soon}</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- INFO -->
  <section class="vi26-info">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.info_n}</span>
      <h2 class="vi26-section-h">{COPY.info_h}</h2>
      <p class="vi26-section-sub">{COPY.info_lede}</p>
    </header>

    <div class="vi26-info-grid">
      {COPY.info_blocks.map((b) => (
        <div class="vi26-info-block">
          <p class="vi26-info-eyebrow mono">{b.eyebrow}</p>
          <h3 class="vi26-info-h">{b.h}</h3>
          <p class="vi26-info-p">{b.p}</p>
        </div>
      ))}
    </div>

    <a class="vi26-cta vi26-cta-big" href={MAP_HREFS[lang]}>
