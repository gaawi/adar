// -----------------------------------------------------------------------------
// 2026 PROGRAM · twelve events across ten days
// -----------------------------------------------------------------------------
interface Event26 {
  day: string;
  date: string;          // YYYY-MM-DD, used for ordering
  time?: string;
  kind: string;
  venue: string;
  municipality: string;
  description?: string;
  image?: string;        // full CDN URL
  eventbrite?: string;   // booking URL — empty until released
  confirmed: boolean;
}

