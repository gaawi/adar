  },
  ast: {
    'Hórreo ganador del concurso 2026':'Hórreu ganador del concursu 2026',
    'Biblioteca del Parador de Corias':'Biblioteca del Parador de Corias',
    'Monasterio de San Antolín de Bedón':'Monasteriu de San Antolín de Bedón',
    'Aula del Oro':'Aula del Oru',
    'Calles de Leiguarda':'Caleyes de Lleiguarda',
