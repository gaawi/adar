  "03": { "title": "La forma de la memoria", "subtitle": "Conciertu de tríu con pianu", "description": "Segunda llectura del programa La forma de la memoria, agora en Llanes. El mesmu tríu interpreta les mesmes obres, pero l'acústica del nuevu espaciu reescribe la pieza. Una manera de comprobar cómo'l llugar tresforma la música: el mesmu repertoriu nun suena igual a la lluz del atapecer nuna villa marinera del oriente qu'na biblioteca d'un parador del occidente." },
  "04": { "title": "UMBRAL ZERO", "subtitle": "Conciertu de música minimalista y arte visual", "description": "Programa de flauta y pianu construyíu sobre'l minimalismu: una música que tiende a cero, que reduz el xestu al mínimu hasta rozar el silenciu —d'ehí'l títulu, «Umbral Zero»—. Guillermo Laporta y Josefina Urraca enllacen el minimalismu de Max Richter, Meredith Monk y Hannah Selin cola desnudez de Satie y de Bach, filaos por «Two Roads», del propiu Laporta. L'Aula del Oru de Belmonte de Miranda, antiguu espaciu espositivu del conceyu, acueye una nueche íntima de cámara con proyección visual integrada nel programa.", "programName": "Umbral Zero" },
  "05": { "title": "Intervención site-specific · Coleutivu Menhir", "subtitle": "Instalación artística abierta · Dos xornaes · Creación site-specific", "description": "Menhir ye un coleutivu d'arte y música que crea pieces d'arte sonoru site-specific. Pa ADAR 2026 firmen un recorríu sonoru xeollocalizáu nel palombar de Lleiguarda: a lo llargo del trayeutu, quien lu camine escuchará elementos sonoros, fragmentos musicales y pallabres que van apaeciendo según l'allugamientu. Pue facese en solitariu o en grupu, y va tar disponible en cualquier momentu demientres les dos xornaes — la ruta pasa a formar parte del paisaxe inmaterial del pueblu.", "programNote": "Dos díes d'intervención nel palombar de Lleiguarda. Recorríos distintos cada xornada, obres orixinales, iguadures ya improvisación." },
  "06": { "title": "The Rest is Silence", "subtitle": "ADAR EN RUTA · Conciertu de música de cámara y arte visual", "description": "Programa-mosaicu construyíu sobre la idea de la soledá. Quince pieces breves del sieglu XX y XXI alternaes con cánones de la Ofrenda Musical de Bach que furrulen como fugues ente los temes. Ligeti, Gubaidúlina, Kurtág, Webern, Penderecki, Stravinsky, Gerhard y Cage construyen una secuencia rota deliberadamente pola regularidá de Bach. El tríu The Rest Project aterriza nel Auditoriu As Quintas d'El Franco con escenografía visual y un programa que s'escucha d'un tirón, ensin aplausos ente pieces.", "programName": "The Rest is Silence" },
  "07": { "title": "Micro conciertu nel Centru ADAR durante l'eclís", "subtitle": "Quintetu con pianu", "description": "Micro conciertu nel Centru ADAR de Lleiguarda, coincidiendo col eclís solar. El quintetu formáu por Maria Florea, Lara Fernández, Daniel Claret, Guillermo Laporta y Josefina Urraca interpreta'l primer movimientu del Quintetu pa pianu n.º 2 en la mayor, op. 81, d'Antonín Dvořák, y «Twilight at Dawn» de Devin Cholodenko." },
  "08": { "title": "Conciertu de música de cámara y arte visual", "subtitle": "ADAR EN RUTA", "description": "So les bóvedes del monasteriu cisterciense de Villanueva de Uscos, fundáu nel sieglu XII, el conxuntu axunta «Twilight at Dawn» de Devin Cholodenko, el segundu movimientu del Tríu de cuerdes de Schubert, l'Andante sostenuto de Joan Magrané —coencargu de L'Auditori de Barcelona—, el Cuartetu con pianu op. 60 de Brahms y dos movimientos del Quintetu op. 81 de Dvořák. Repertoriu clásicu y contemporáneu lleíu nuna nave del sieglu XII." },
  "09": { "venueNote": "Dos pases de 20 minutos · Sede anunciada l’1 d’agostu", "title": "Equilibrium", "subtitle": "Muestra de residencia · The Rest Project", "description": "«Equilibrium» parte del 3 como númberu del equilibriu —espíritu, alma y cuerpu—: trés músicos y trés compositores n'armonía. Coincidiendo col centenariu de György Kurtág, el tríu The Rest Project amuesa'l trabayu desarrolláu na so residencia artística nel hórreu, un programa abiertu y en construcción. A lo llargo del conciertu resuena amás la poesía de Joan Margarit, con quien el grupu comparte un vencelu personal.", "programName": "Equilibrium" },
  "10": { "title": "Paséu sonoru en Lleiguarda", "subtitle": "Creación site-specific", "description": "Caminata sonora pel valle con paraes en distintes estaciones del recorríu. El quintetu Hoffman / Brazauskas / Saeijs / Laporta / Urraca interpreta obres orixinales, iguadures ya improvisación a lo llargo del trayeutu, integrando'l paisaxe na partitura. Aforu llimitáu por motivos de movilidá: el grupu camina xunto al públicu ente estación y estación. Encaláu cómodu recomendáu.", "programNote": "Creación site-specific con obres orixinales, iguadures ya improvisación a lo llargo del valle de Lleiguarda." },
  "11": { "title": "Zarru · Conciertu de quintetu y espicha", "subtitle": "Zarru de la VI edición", "description": "Zarru de la VI edición. El mesmu quintetu que firmó'l paséu sonoru del día anterior s'axunta de nuevu na ilesia parroquial de Lleiguarda pa un programa concentráu que percuerre a Vivaldi na transcripción de Bach, Mendelssohn y el primer movimientu del Tríu pa clarinete de Brahms, y sigue con Ma mère l'Oye de Ravel, Musica Ricercata de Ligeti, sweet air de David Lang y una mazurca tradicional (Monterosano Mazurka) pa despidir. Tres del conciertu, espicha abierta pa tol públicu nel campu de la ilesia. La nueche llarga que despide'l festival." }
},
};
const DOW_I18N: Record<string, Record<string, string>> = {
  en:  { 'Martes':'Tuesday','Miércoles':'Wednesday','Jueves':'Thursday','Viernes':'Friday','Sábado':'Saturday','Domingo':'Sunday','Sábado–Domingo':'Saturday–Sunday' },
  ast: { 'Martes':'Martes','Miércoles':'Miércoles','Jueves':'Xueves','Viernes':'Vienres','Sábado':'Sábadu','Domingo':'Domingu','Sábado–Domingo':'Sábadu–Domingu' },
};
const ROLE_I18N: Record<string, Record<string, string>> = {
