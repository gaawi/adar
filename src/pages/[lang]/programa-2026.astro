  history: number[];          // past edition years ADAR has performed here
  date: string;               // 2026 night label
  dow: string;                // day of week
  time: string;
  kind: string;
  photos: string[];           // CDN URLs
  memoriaSlug?: string;       // most recent post slug to link
  website?: string;           // venue's official website (only when verifiable)
  eventbrite?: string;        // 2026 RSVP URL — empty until released
  confirmed: boolean;         // whether 2026 venue is confirmed
}

