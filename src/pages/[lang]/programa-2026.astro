const HOME_HREFS: Record<Lang, string> = {
  es: '/es/adar/',
  en: '/en/adar-festival/',
  ast: '/ast/festival-adar/',
};
const MAP_HREFS: Record<Lang, string> = {
  es: '/es/mapa-de-acciones/',
  en: '/en/map-of-actions/',
  ast: '/ast/mapa-dacciones/',
};

const heroImage = CDN + 'adar25fx30/C1543T01.jpg';
---

<BaseLayout
  title={COPY.title}
  lang={lang}
  permalink={`/${lang}/programa-2026/`}
  featuredImage={heroImage}
  translations={{
    es: '/es/programa-2026/',
    en: '/en/programa-2026/',
    ast: '/ast/programa-2026/',
  }}
>

  <!-- HERO -->
  <section class="p26-hero">
    <div class="p26-hero-img">
      <img src={heroImage} alt="Festival ADAR 2026" loading="eager" />
    </div>
    <div class="p26-hero-veil"></div>

    <div class="p26-hero-body">
      <span class="p26-hero-pill mono">{COPY.hero_pill}</span>
      <p class="p26-hero-dates mono">{COPY.hero_dates}</p>
      <h1 class="p26-hero-h">
        {COPY.hero_title_pre} <em>{COPY.hero_title_em}</em> {COPY.hero_title_post}
      </h1>
      <p class="p26-hero-lede">{COPY.hero_lede}</p>

      <ul class="p26-hero-stats">
        {COPY.stats.map((s) => (
          <li>
            <span class="p26-stat-n">{s.n}</span>
            <span class="p26-stat-l mono">{s.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- INTRO -->
  <section class="p26-intro">
    <p class="p26-eyebrow mono">{COPY.intro_eyebrow}</p>
    <h2 class="p26-h">
      {COPY.intro_h_pre} <em>{COPY.intro_h_em}</em>{COPY.intro_h_post}
    </h2>
    <div class="p26-intro-cols">
      <p>{COPY.intro_p1}</p>
      <p>{COPY.intro_p2}</p>
    </div>
  </section>

  <!-- SCHEDULE -->
  <section class="p26-schedule">
    <header class="p26-schedule-head">
      <p class="p26-eyebrow mono">{COPY.schedule_eyebrow}</p>
      <h2 class="p26-h">
        {COPY.schedule_h_pre} <em>{COPY.schedule_h_em}</em>{COPY.schedule_h_post}
      </h2>
    </header>

    <ol class="p26-list">
      {PROGRAM_2026.map((ev, i) => (
        <li class={`p26-event ${ev.confirmed ? 'is-confirmed' : 'is-tbc'}`}>
          <div class="p26-event-media">
            {ev.image ? (
              <img src={ev.image} alt={ev.venue} loading="lazy" />
            ) : (
              <div class="p26-event-placeholder">
                <span class="mono">{COPY.tbc}</span>
              </div>
            )}
            <span class="p26-event-n mono">{String(i + 1).padStart(2, '0')}</span>
          </div>

          <div class="p26-event-body">
            <div class="p26-event-when">
              <span class="p26-event-day mono">{ev.day}</span>
              {ev.time && <span class="p26-event-time mono">· {ev.time}</span>}
              <span class={`p26-event-status mono ${ev.confirmed ? '' : 'is-tbc'}`}>
                {ev.confirmed ? COPY.confirmed : COPY.tbc}
              </span>
            </div>

            <p class="p26-event-kind mono">{ev.kind}</p>
            <h3 class="p26-event-venue">{ev.venue}</h3>
            <p class="p26-event-muni mono">{ev.municipality}</p>

            {ev.description && <p class="p26-event-desc">{ev.description}</p>}

            <p class="p26-event-free mono">{COPY.free}</p>

            <div class="p26-event-cta">
              {ev.eventbrite ? (
                <a class="p26-rsvp" href={ev.eventbrite} target="_blank" rel="noopener">
                  <span class="p26-arr">→</span> {COPY.rsvp}
                </a>
              ) : (
                <span class="p26-rsvp p26-rsvp-soon">{COPY.soon}</span>
              )}
            </div>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- VENUES MAP CTA -->
  <section class="p26-venues">
    <p class="p26-eyebrow mono">{COPY.venues_eyebrow}</p>
    <h2 class="p26-h">{COPY.venues_h}</h2>
    <p class="p26-sub">{COPY.venues_sub}</p>
    <a class="p26-cta p26-cta-ghost" href={MAP_HREFS[lang]}>
      <span class="p26-arr">→</span> {COPY.venues_cta}
    </a>
  </section>

  <!-- FOLLOW -->
  <section class="p26-follow">
    <p class="p26-eyebrow mono">{COPY.follow_eyebrow}</p>
    <h2 class="p26-h">{COPY.follow_h}</h2>
    <p class="p26-sub">{COPY.follow_sub}</p>
    <div class="p26-actions">
      <a class="p26-cta"
         href="mailto:leiguardamusic@gmail.com?subject=Bolet%C3%ADn%20Festival%20ADAR%202026&body=Hola%2C%20me%20gustar%C3%ADa%20recibir%20avisos%20del%20programa%202026.">
        <span class="p26-arr">→</span> {COPY.follow_email}
      </a>
      <a class="p26-cta p26-cta-ghost" href="https://instagram.com/festivaladar" target="_blank" rel="noopener">
        <span class="p26-arr">→</span> {COPY.follow_ig}
      </a>
      <a class="p26-cta p26-cta-ghost" href="https://www.youtube.com/@festivaladar" target="_blank" rel="noopener">
        <span class="p26-arr">→</span> {COPY.follow_yt}
      </a>
    </div>
  </section>

  <!-- PRESS -->
  <section class="p26-press">
    <p class="p26-eyebrow mono">{COPY.press_eyebrow}</p>
    <h2 class="p26-h">{COPY.press_h}</h2>
    <p class="p26-sub">{COPY.press_sub}</p>
    <a class="p26-cta p26-cta-ghost"
       href="mailto:leiguardamusic@gmail.com?subject=Dosier%20de%20prensa%20Festival%20ADAR%202026">
      <span class="p26-arr">→</span> {COPY.press_cta}
    </a>
  </section>

</BaseLayout>
