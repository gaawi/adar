// Build a unique artist list (preserving instrument labels from first occurrence)
const seen = new Set<string>();
const ARTISTS = EVENTS.flatMap((e) => e.artists).filter((a) => {
  if (seen.has(a.name)) return false;
  seen.add(a.name);
  return true;
});

const MAP_HREFS: Record<Lang, string> = {
  es: '/es/mapa-de-acciones/',
  en: '/en/map-of-actions/',
  ast: '/ast/mapa-dacciones/',
};

const POSTER_BG = CDN + 'adar25fx30/DSC01680.jpg';
---

<BaseLayout
  title={COPY.title}
  lang={lang}
  permalink={`/${lang}/programa-2026/`}
  featuredImage={POSTER_BG}
  bodyClass="vi26-body"
  translations={{
    es: '/es/programa-2026/',
    en: '/en/programa-2026/',
    ast: '/ast/programa-2026/',
  }}
>

<div class="vi26">

  <!-- TOP MARQUEE -->
  <div class="vi26-topbar mono">
    <div class="vi26-topbar-track"><span>{COPY.topbar}</span><span>{COPY.topbar}</span><span>{COPY.topbar}</span></div>
  </div>

  <!-- POSTER HERO -->
  <section class="vi26-poster">
    <div class="vi26-poster-bg" aria-hidden="true">
      <img src={POSTER_BG} alt="" loading="eager" />
    </div>
    <div class="vi26-poster-grain" aria-hidden="true"></div>

    <!-- Decorative geometry -->
    <svg class="vi26-poster-rules" viewBox="0 0 1200 800" preserveAspectRatio="none" aria-hidden="true">
      <line x1="0" y1="120" x2="1200" y2="120" stroke="currentColor" stroke-width="1" />
      <line x1="0" y1="680" x2="1200" y2="680" stroke="currentColor" stroke-width="1" />
      <line x1="80"   y1="0" x2="80"   y2="800" stroke="currentColor" stroke-width="1" stroke-dasharray="2 6" />
      <line x1="1120" y1="0" x2="1120" y2="800" stroke="currentColor" stroke-width="1" stroke-dasharray="2 6" />
    </svg>

    <!-- Corner marks -->
    <span class="vi26-corner vi26-corner-tl" aria-hidden="true">+</span>
    <span class="vi26-corner vi26-corner-tr" aria-hidden="true">+</span>
    <span class="vi26-corner vi26-corner-bl" aria-hidden="true">+</span>
    <span class="vi26-corner vi26-corner-br" aria-hidden="true">+</span>

    <!-- Top band -->
    <div class="vi26-poster-top mono">
      <span>{COPY.poster_kicker}</span>
      <span>{COPY.poster_year}</span>
    </div>

    <!-- Center composition -->
    <div class="vi26-poster-stack">
      <p class="vi26-poster-date">{COPY.poster_dates}</p>
      <p class="vi26-poster-mo">{COPY.poster_month}</p>

      <div class="vi26-poster-mark" aria-hidden="true">
        <span class="vi26-poster-vi">VI</span>
      </div>

      <h1 class="vi26-poster-h"><span>{COPY.poster_h}</span></h1>
      <p class="vi26-poster-sub mono">{COPY.poster_sub}</p>
    </div>

    <!-- Bottom band: stats + CTAs -->
    <div class="vi26-poster-bottom">
      <ul class="vi26-poster-stats mono">
        <li>{COPY.poster_stat_a}</li>
        <li>{COPY.poster_stat_b}</li>
        <li>{COPY.poster_stat_c}</li>
        <li>{COPY.poster_stat_d}</li>
      </ul>
      <div class="vi26-poster-actions">
        <a class="vi26-cta" href="#program"><span class="vi26-arr">↓</span> {COPY.cta_program}</a>
        <a class="vi26-cta vi26-cta-ghost"
           href="mailto:leiguardamusic@gmail.com?subject=Dosier%20de%20prensa%20Festival%20ADAR%202026">
          <span class="vi26-arr">→</span> {COPY.cta_press}
        </a>
      </div>
    </div>
  </section>

  <!-- ARTIST TICKER -->
  <div class="vi26-ticker" aria-hidden="true">
    <div class="vi26-ticker-track">
      <span>{ARTISTS.map((a) => a.name).join(' · ')} · {ARTISTS.map((a) => a.name).join(' · ')}</span>
    </div>
  </div>

  <!-- PROGRAM -->
  <section class="vi26-venues" id="program">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.nights_n}</span>
      <h2 class="vi26-section-h">{COPY.nights_h}</h2>
      <p class="vi26-section-sub">{COPY.nights_sub}</p>
    </header>

    <ol class="vi26-venue-list">
      {EVENTS.map((e, idx) => e.rest ? (
        <li class="vi26-event-rest">
          <span class="vi26-rest-date mono"><span class="vi26-dow">{e.dow}</span> {e.fullDate}</span>
          <span class="vi26-rest-label">{COPY.rest}</span>
          <span class="vi26-rest-sub mono">{COPY.rest_sub}</span>
        </li>
      ) : (
        <li class={`vi26-venue ${idx % 2 === 1 ? 'is-reverse' : ''}`}>
          {e.photos.length > 0 ? (
            <div class="vi26-slider" data-slider>
              <div class="vi26-slider-track" data-slider-track>
                {e.photos.map((src, i) => (
                  <div class="vi26-slide">
                    <img src={src} alt={`${e.venue} · ${i + 1}`} loading="lazy" />
                  </div>
                ))}
              </div>
              {e.photos.length > 1 && (
                <>
                  <button class="vi26-slider-btn vi26-slider-prev" type="button" aria-label="Prev" data-slider-prev>‹</button>
                  <button class="vi26-slider-btn vi26-slider-next" type="button" aria-label="Next" data-slider-next>›</button>
                  <div class="vi26-slider-dots" data-slider-dots>
                    {e.photos.map((_, i) => <span class={`vi26-dot ${i === 0 ? 'is-active' : ''}`}></span>)}
                  </div>
                </>
              )}
              <div class="vi26-slider-counter mono"><span data-slider-current>1</span> / {e.photos.length}</div>
            </div>
          ) : (
            <div class="vi26-slider vi26-slider-empty">
              <span class="mono">{COPY.tbc}</span>
            </div>
          )}

          <div class="vi26-venue-meta">
            <div class="vi26-venue-mark">
              <span class="vi26-venue-n mono">N° {e.n}</span>
              <span class="vi26-venue-date mono"><span class="vi26-dow">{e.dow}</span> {e.fullDate}</span>
              {e.tbc && <span class="vi26-venue-tbc mono">{COPY.tbc}</span>}
            </div>

            <h3 class="vi26-venue-name">{e.title}</h3>
            {e.subtitle && <p class="vi26-event-sub mono">↳ {e.subtitle}</p>}

            <dl class="vi26-event-block">
              <dt class="mono">{COPY.venue_h}</dt>
              <dd>
                <span class="vi26-fact-line">{e.venue}</span>
                <span class="vi26-fact-place mono">{e.municipality}</span>
                {e.venueNote && <span class="vi26-fact-note mono">{e.venueNote}</span>}
              </dd>
            </dl>

            <dl class="vi26-event-block">
              <dt class="mono">{COPY.program_h}{e.programName ? ` · ${e.programName}` : ''}</dt>
              <dd>
                {e.pieces.length > 0 ? (
                  <ol class="vi26-program">
                    {e.pieces.map((p) => (
                      <li>
                        <span class="vi26-program-composer">{p.composer}{p.years ? <span class="vi26-program-years mono"> {p.years}</span> : null}</span>
                        <span class="vi26-program-piece"> · <em>{p.piece}</em></span>
                        {p.duration && <span class="vi26-program-dur mono"> [{p.duration}]</span>}
                      </li>
                    ))}
                  </ol>
                ) : (
                  <p class="vi26-program-note">{e.programNote || COPY.program_tbd}</p>
                )}
                {e.totalDuration && <p class="vi26-program-total mono">{COPY.duration_total} · {e.totalDuration}</p>}
              </dd>
            </dl>

            <dl class="vi26-event-block">
              <dt class="mono">{COPY.artists_h}</dt>
              <dd>
                <ul class="vi26-artist-line">
                  {e.artists.map((a) => (
                    <li>
                      <span class="vi26-artist-l-name">{a.name}</span>
                      <span class="vi26-artist-l-role mono"> · {a.role}</span>
                    </li>
                  ))}
                </ul>
              </dd>
            </dl>

            <div class="vi26-venue-links">
              {e.memoriaSlug && (
                <a class="vi26-link" href={`/${lang}/${e.memoriaSlug}/`}>
                  <span class="vi26-arr">↗</span> {COPY.visit_h} {e.memoriaYear}
                </a>
              )}
              {e.venueWebsite && (
                <a class="vi26-link" href={e.venueWebsite} target="_blank" rel="noopener">
                  <span class="vi26-arr">↗</span> {COPY.web_h}
                </a>
              )}
              {e.eventbrite ? (
                <a class="vi26-cta vi26-cta-small" href={e.eventbrite} target="_blank" rel="noopener">
                  <span class="vi26-arr">→</span> {COPY.rsvp}
                </a>
              ) : (
                <span class="vi26-cta vi26-cta-small vi26-cta-disabled">{COPY.soon}</span>
              )}
            </div>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- CARTEL -->
  <section class="vi26-cartel">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.cartel_n}</span>
      <h2 class="vi26-section-h">{COPY.cartel_h}</h2>
      <p class="vi26-section-sub">{COPY.cartel_sub}</p>
    </header>

    <ul class="vi26-cartel-list">
      {ARTISTS.map((a) => (
        <li class="vi26-cartel-row">
          <span class="vi26-cartel-name">{a.name}</span>
          <span class="vi26-cartel-role mono">{a.role}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- CALENDAR -->
  <section class="vi26-calendar">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.cal_n}</span>
      <h2 class="vi26-section-h">{COPY.cal_h}</h2>
      <p class="vi26-section-sub">{COPY.cal_sub}</p>
    </header>

    <div class="vi26-table-wrap">
      <table class="vi26-table">
        <thead>
          <tr>
            <th class="mono">{COPY.th_n}</th>
            <th class="mono">{COPY.th_date}</th>
            <th class="mono">{COPY.th_kind}</th>
            <th class="mono">{COPY.th_venue}</th>
            <th class="mono">{COPY.th_artists}</th>
            <th class="mono">{COPY.th_rsvp}</th>
          </tr>
        </thead>
        <tbody>
          {EVENTS.map((e) => e.rest ? (
            <tr class="is-tbc is-rest">
              <td class="mono vi26-td-n">—</td>
              <td class="mono"><span class="vi26-dow">{e.dow}</span> {e.fullDate}</td>
              <td class="mono vi26-td-kind">{COPY.rest}</td>
              <td class="vi26-td-venue">—</td>
              <td class="mono">—</td>
              <td>—</td>
            </tr>
          ) : (
            <tr class={e.tbc ? 'is-tbc' : ''}>
              <td class="mono vi26-td-n">{e.n}</td>
              <td class="mono"><span class="vi26-dow">{e.dow}</span> {e.fullDate}</td>
              <td class="mono vi26-td-kind">{e.subtitle?.split('·')[0]?.trim() || e.title}</td>
              <td class="vi26-td-venue">{e.venue}{e.municipality ? <span class="mono vi26-td-muni"> · {e.municipality}</span> : null}</td>
              <td class="mono">{e.artists.map((a) => a.name.split(' ')[0]).join(' · ')}</td>
              <td>
                {e.eventbrite ? (
                  <a class="vi26-rsvp-mini" href={e.eventbrite} target="_blank" rel="noopener">{COPY.rsvp} ↗</a>
                ) : (
                  <span class="vi26-rsvp-mini vi26-rsvp-soon mono">{COPY.soon}</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- INFO -->
  <section class="vi26-info">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.info_n}</span>
      <h2 class="vi26-section-h">{COPY.info_h}</h2>
      <p class="vi26-section-sub">{COPY.info_lede}</p>
    </header>

    <div class="vi26-info-grid">
      {COPY.info_blocks.map((b) => (
        <div class="vi26-info-block">
          <p class="vi26-info-eyebrow mono">{b.eyebrow}</p>
          <h3 class="vi26-info-h">{b.h}</h3>
          <p class="vi26-info-p">{b.p}</p>
        </div>
      ))}
    </div>

    <a class="vi26-cta vi26-cta-big" href={MAP_HREFS[lang]}>
      <span class="vi26-arr">→</span> {lang === 'en' ? 'See venue map' : 'Ver mapa de sedes'}
    </a>
  </section>

  <!-- FOLLOW -->
  <section class="vi26-follow">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.follow_n}</span>
      <h2 class="vi26-section-h">{COPY.follow_h}</h2>
      <p class="vi26-section-sub">{COPY.follow_sub}</p>
    </header>
    <div class="vi26-follow-actions">
      <a class="vi26-cta"
         href="mailto:leiguardamusic@gmail.com?subject=Bolet%C3%ADn%20Festival%20ADAR%202026&body=Hola%2C%20me%20gustar%C3%ADa%20recibir%20avisos%20del%20programa%202026.">
        <span class="vi26-arr">→</span> {COPY.follow_email}
      </a>
      <a class="vi26-cta vi26-cta-ghost" href="https://instagram.com/festivaladar" target="_blank" rel="noopener">
        <span class="vi26-arr">↗</span> {COPY.follow_ig}
      </a>
      <a class="vi26-cta vi26-cta-ghost" href="https://www.youtube.com/@festivaladar" target="_blank" rel="noopener">
        <span class="vi26-arr">↗</span> {COPY.follow_yt}
      </a>
    </div>
  </section>

  <!-- CREDITS -->
  <footer class="vi26-credits">
    <span class="vi26-section-n mono">{COPY.credits_n}</span>
    <h2 class="vi26-section-h">{COPY.credits_h}</h2>
    <dl class="vi26-credits-list">
      <dt class="mono">{COPY.curated}</dt>
      <dd>Guillermo Laporta · Josefina Urraca</dd>
      <dt class="mono">{COPY.produced}</dt>
      <dd>Asociación ADAR · Leiguarda, Belmonte de Miranda</dd>
      <dt class="mono">{COPY.supported}</dt>
      <dd>Principado de Asturias · Ayuntamientos anfitriones · partners institucionales y privados</dd>
    </dl>
    <p class="vi26-credits-foot mono">
      © 2026 ADAR · LEIGUARDA / BELMONTE DE MIRANDA · ASTURIES / ES
    </p>
  </footer>

</div>

<script>
  document.querySelectorAll('[data-slider]').forEach((root) => {
    const track = root.querySelector('[data-slider-track]');
    const dots  = root.querySelectorAll('[data-slider-dots] .vi26-dot');
    const current = root.querySelector('[data-slider-current]');
    const prev  = root.querySelector('[data-slider-prev]');
    const next  = root.querySelector('[data-slider-next]');
    if (!track) return;
    let raf = 0;
    const updateActive = () => {
      const slideW = track.clientWidth;
      if (!slideW) return;
      const i = Math.round(track.scrollLeft / slideW);
      dots.forEach((d, idx) => d.classList.toggle('is-active', idx === i));
      if (current) current.textContent = String(i + 1);
    };
    track.addEventListener('scroll', () => {
      if (raf) return;
      raf = requestAnimationFrame(() => { raf = 0; updateActive(); });
    }, { passive: true });
    const scrollBy = (dir) => { track.scrollBy({ left: dir * track.clientWidth, behavior: 'smooth' }); };
    prev && prev.addEventListener('click', () => scrollBy(-1));
    next && next.addEventListener('click', () => scrollBy(1));
    dots.forEach((d, i) => d.addEventListener('click', () => {
      track.scrollTo({ left: i * track.clientWidth, behavior: 'smooth' });
    }));
  });
</script>

</BaseLayout>
