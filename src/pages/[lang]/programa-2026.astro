const MUNI_I18N: Record<string, Record<string, string>> = {
  en: {
    'Hórreo ganador del concurso':'Winning hórreo of the competition',
    'Monasterio de San Antolín de Bedón (Llanes)':'Monastery of San Antolín de Bedón (Llanes)',
    'Auditorio As Quintas, A Caridá (El Franco)':'As Quintas Auditorium, A Caridá (El Franco)',
    'Monasterio de Villanueva de Oscos':'Monastery of Villanueva de Oscos',
    'Calles de Leiguarda (Belmonte de Miranda)':'Streets of Leiguarda (Belmonte de Miranda)',
    'Iglesia de Leiguarda (Belmonte de Miranda)':'Church of Leiguarda (Belmonte de Miranda)',
  },
  ast: {
    'Hórreo ganador del concurso':'Hórreu ganador del concursu',
    'Monasterio de San Antolín de Bedón (Llanes)':'Monasteriu de San Antolín de Bedón (Llanes)',
    'Aula del Oro (Belmonte de Miranda)':'Aula del Oru (Belmonte de Miranda)',
    'Centro ADAR, Leiguarda (Belmonte de Miranda)':'Centru ADAR, Lleiguarda (Belmonte de Miranda)',
    'Auditorio As Quintas, A Caridá (El Franco)':'Auditoriu As Quintas, A Caridá (El Franco)',
    'Monasterio de Villanueva de Oscos':'Monasteriu de Villanueva de Uscos',
    'Calles de Leiguarda (Belmonte de Miranda)':'Caleyes de Lleiguarda (Belmonte de Miranda)',
    'Iglesia de Leiguarda (Belmonte de Miranda)':'Ilesia de Lleiguarda (Belmonte de Miranda)',
  },
};
const ADDR_I18N: Record<string, Record<string, string>> = {
  en:  { 'Sede por anunciar':'Venue to be announced' },
  ast: { 'Sede por anunciar':'Sede por anunciar' },
};
function tDict(map: Record<string, Record<string, string>>, val: string): string {
  if (lang === 'es' || !val) return val;
  return (map[lang] && map[lang][val]) || val;
}
const PIECE_I18N: Record<string, Record<string, string[]>> = {
  en: {"01": ["Diferencias sobre el Canto del Cavallero", "Folías de España (from Flores de Música)", "Suite No. 1 in G major Z. 660 — Prelude · Almand · Corant · Minuet", "Ground in C minor", "Sonata K. 213 in D minor", "Sonata K. 27 in B minor", "Ciaccona · from the Partita for violin in D minor (trans. J. Brahms)"], "02": ["Nocturne for violin and piano", "Trio élégiaque No. 1 in G minor", "Piano Trio No. 1", "Piano Trio", "Louange à l'immortalité de Jésus · from the Quartet for the End of Time", "Piano Trio No. 1, Op. 8"], "03": ["Nocturne for violin and piano", "Trio élégiaque No. 1 in G minor", "Piano Trio No. 1", "Piano Trio", "Louange à l'immortalité de Jésus · from the Quartet for the End of Time", "Piano Trio No. 1, Op. 8"], "04": ["Vladimir's Blues", "Two Roads — I. Walts · II. Circle of Choices", "imsotired (: (2023), for amplified flute and electronics", "Cello Suite No. 1 in G major, BWV 1007", "Dream Journal", "Trois Gymnopédies — I. Lent et douloureux · II. Lent et triste · III. Lent et grave", "Romance", "Night Song"], "06": ["Hora Lunga", "Canon a 2 Cancrizans", "Listen to the Still Small Voice Within", "Az Hit", "Canon a 2 per Motum Contrarium", "Allegro con Fuoco", "Satz", "Canon a 2 Violini al Unisono", "Pizzicato-Arco", "Vivace", "Virág az Ember", "Canon a 2 per Tonos", "Élégie", "4′33″", "Ricercar a 3"], "07": ["Piano Quintet No. 2 in A major, Op. 81 — I. Allegro, ma non tanto", "Twilight at Dawn"], "08": ["Twilight at Dawn", "String Trio D.471 — II. Andante sostenuto", "Andante sostenuto · co-commissioned by L'Auditori de Barcelona", "Piano Quartet No. 3 in C minor, Op. 60 — I & II movements", "Piano Quintet No. 2 in A major, Op. 81 — I. Allegro · II. Dumka"], "11": ["Concerto VII from L'Estro Armonico (arr. J. S. Bach) — Allegro · Largo · Allegro", "Konzertstück No. 2, Op. 114 — Andante", "Trio for clarinet, cello and piano in A minor, Op. 114 — I. movement", "Ma mère l'Oye", "Musica Ricercata", "sweet air", "Monterosano Mazurka (arr. J. Hoffman)"]},
  ast: {"01": ["Diferencias sobre el Canto del Cavallero", "Folías de España (de Flores de Música)", "Suite n.º 1 en sol mayor Z. 660 — Prelude · Almand · Corant · Minuet", "Ground en do menor", "Sonata K. 213 en re menor", "Sonata K. 27 en si menor", "Ciaccona · de la Partita pa violín en re menor (trans. J. Brahms)"], "02": ["Nocturne pa violín y pianu", "Trío élégiaque n.º 1 en sol menor", "Tríu con pianu n.º 1", "Tríu con pianu", "Louange à l'immortalité de Jésus · del Cuartetu pal fin de los tiempos", "Tríu con pianu n.º 1, op. 8"], "03": ["Nocturne pa violín y pianu", "Trío élégiaque n.º 1 en sol menor", "Tríu con pianu n.º 1", "Tríu con pianu", "Louange à l'immortalité de Jésus · del Cuartetu pal fin de los tiempos", "Tríu con pianu n.º 1, op. 8"], "04": ["Vladimir's Blues", "Two Roads — I. Walts · II. Circle of Choices", "imsotired (: (2023), pa flauta amplificada y electrónica", "Suite pa violonchelu n.º 1 en sol mayor, BWV 1007", "Dream Journal", "Trois Gymnopédies — I. Lent et douloureux · II. Lent et triste · III. Lent et grave", "Romance", "Night Song"], "06": ["Hora Lunga", "Canon a 2 Cancrizans", "Listen to the Still Small Voice Within", "Az Hit", "Canon a 2 per Motum Contrarium", "Allegro con Fuoco", "Satz", "Canon a 2 Violini al Unisono", "Pizzicato-Arco", "Vivace", "Virág az Ember", "Canon a 2 per Tonos", "Élégie", "4′33″", "Ricercar a 3"], "07": ["Quintetu pa pianu n.º 2 en la mayor, op. 81 — I. Allegro, ma non tanto", "Twilight at Dawn"], "08": ["Twilight at Dawn", "Tríu de cuerdes D.471 — II. Andante sostenuto", "Andante sostenuto · coencargu de L'Auditori de Barcelona", "Cuartetu con pianu n.º 3 en do menor, op. 60 — I y II movimientos", "Quintetu pa pianu n.º 2 en la mayor, op. 81 — I. Allegro · II. Dumka"], "11": ["Concerto VII de L'Estro Armonico (arr. J. S. Bach) — Allegro · Largo · Allegro", "Konzertstück n.º 2, op. 114 — Andante", "Tríu pa clarinete, violonchelu y pianu en la menor, op. 114 — I. movimientu", "Ma mère l'Oye", "Musica Ricercata", "sweet air", "Monterosano Mazurka (arr. J. Hoffman)"]},
};
function tPiece(e: Event, i: number, piece: string): string {
  if (lang === 'es') return piece;
  const arr = PIECE_I18N[lang] && PIECE_I18N[lang][e.n];
  return (arr && arr[i] != null) ? arr[i] : piece;
}

function tEv(e: Event, field: string): any {
  if (lang === 'es') return (e as any)[field];
  const o = EV_I18N[lang] && EV_I18N[lang][e.n];
  return (o && o[field] != null) ? o[field] : (e as any)[field];
}
const LBL = ({
  es:  { when: 'Cuándo', where: 'Dónde', map: 'Ver mapa', timeTbc: 'Horario por confirmar' },
  en:  { when: 'When',   where: 'Where', map: 'View map', timeTbc: 'Hours TBC' },
  ast: { when: 'Cuándo', where: 'Ónde',  map: 'Ver mapa', timeTbc: 'Horariu por confirmar' },
} as Record<string, { when: string; where: string; map: string; timeTbc: string }>)[lang];

const MAP_HREFS: Record<Lang, string> = {
  es: '/es/mapa-de-acciones/',
  en: '/en/map-of-actions/',
  ast: '/ast/mapa-dacciones/',
};

const PRESS_HREF: Record<Lang, string> = {
  es:  '/es/nota-de-prensa-adar-2026/',
  en:  '/en/press-release-adar-2026/',
  ast: '/ast/nota-de-prensa-adar-2026/',
};

const POSTER_BG = '/posters/adar-2026.png';
---

<BaseLayout
  title={COPY.title}
  lang={lang}
  permalink={`/${lang}/programa-2026/`}
  featuredImage={POSTER_BG}
  bodyClass="vi26-body"
  translations={{
    es: '/es/programa-2026/',
    en: '/en/programa-2026/',
    ast: '/ast/programa-2026/',
  }}
>

<div class="vi26">

  <!-- HERO · banner a ancho completo basado en el cartel oficial 2026 -->
  <section class="prog-current vi26-poster-hero">
    <a class="vi26-poster-hero-banner" href="/posters/adar-2026.png" target="_blank" rel="noopener" aria-label={COPY.hero_h}>
      <img src="/posters/adar-2026.png" alt="Cartel oficial del Festival ADAR 2026" />
    </a>
    <div class="vi26-poster-hero-bar">
      <div class="vi26-poster-hero-bar-inner">
        <div class="vi26-poster-hero-txt">
          <span class="prog-current-pill">{COPY.poster_kicker}</span>
          <h1 class="vi26-hero-title">{COPY.hero_h}</h1>
          <p class="vi26-hero-tag">{COPY.hero_tag}</p>
        </div>
        <div class="prog-current-ctas">
          <a class="prog-current-cta" href="#program">
            <span class="prog-arr">↓</span>
            {COPY.cta_program}
          </a>
          <a class="prog-current-cta prog-current-cta-ghost" href={PRESS_HREF[lang]}>
            <span class="prog-arr">→</span>
            {COPY.cta_press}
          </a>
          <a class="vi26-poster-hero-dl mono" href="/posters/adar-2026.png" download>
            {lang === 'en' ? 'Download poster ↓' : lang === 'ast' ? 'Descargar cartelu ↓' : 'Descargar cartel ↓'}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PROGRAM -->
  <section class="vi26-venues" id="program">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.nights_n}</span>
      <h2 class="vi26-section-h">{COPY.nights_h}</h2>
      <p class="vi26-section-sub">{COPY.nights_sub}</p>
    </header>

    <ol class="vi26-event-list">
      {EVENTS.filter((e) => !e.rest).map((e) => {
        const title = tEv(e, 'title');
        const subtitle = tEv(e, 'subtitle');
        const description = tEv(e, 'description');
        const programName = tEv(e, 'programName');
        const programNote = tEv(e, 'programNote');
        const kind = subtitle ? subtitle.split('·')[0].trim() : '';
        const isLongProgram = e.pieces.length > 8;
        return (
          <li class="vi26-event" id={`event-${e.n}`}>
            {e.photo ? (
              <figure class="vi26-cover">
                <img src={e.photo} alt={e.venue} loading="lazy" />
              </figure>
            ) : (
              <div class="vi26-cover vi26-cover-empty">
                <span class="mono">{COPY.soon}</span>
              </div>
            )}

            <div class="vi26-content">
              <p class="vi26-event-muni">{tDict(MUNI_I18N, e.municipality)}</p>
              <h3 class="vi26-event-title">{title}</h3>
              {subtitle && <p class="vi26-event-sub mono">↳ {subtitle}</p>}

              {description && <p class="vi26-event-desc">{description}</p>}

              {e.pieces.length > 0 ? (
                <div class="vi26-program-wrap">
                  <p class="vi26-block-label mono">{COPY.program_h}{programName ? ` · ${programName}` : ''}</p>
                  <ol class={`vi26-program ${isLongProgram ? 'is-multi' : ''}`}>
                    {e.pieces.map((p, i) => (
                      <li>
                        <span class="vi26-program-composer">{p.composer}{p.years ? <span class="vi26-program-years mono"> {p.years}</span> : null}</span>
                        <span class="vi26-program-piece"> · <em>{tPiece(e, i, p.piece)}</em></span>
                      </li>
                    ))}
                  </ol>
                </div>
              ) : programNote ? (
                <div class="vi26-program-wrap">
                  <p class="vi26-block-label mono">{COPY.program_h}</p>
                  <p class="vi26-program-note">{programNote}</p>
                </div>
              ) : null}

              <div class="vi26-artists-wrap">
                <p class="vi26-block-label mono">{COPY.artists_h}</p>
                <ul class="vi26-artist-line">
                  {e.artists.map((a) => (
                    <li>
                      <span class="vi26-artist-l-name">{a.name}</span>
                      <span class="vi26-artist-l-role mono"> · {tDict(ROLE_I18N, a.role)}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="vi26-aside-info">
              <p class="vi26-aside-n mono">N° {e.n}</p>

              <!-- CUÁNDO -->
              <div class="vi26-aside-when">
                <span class="vi26-aside-when-label mono">{LBL.when}</span>
                <span class="vi26-aside-when-dow">{tDict(DOW_I18N, e.dow)}</span>
                <span class="vi26-aside-when-date">{e.fullDate}</span>
                {e.time
                  ? <span class="vi26-aside-when-time mono">{e.time}{e.time.includes('—') ? '' : 'h'}</span>
                  : e.timeTbc && <span class="vi26-aside-when-time mono">{LBL.timeTbc}</span>}
              </div>

              <!-- DÓNDE -->
              <div class="vi26-aside-where">
                <span class="vi26-aside-where-label mono">{LBL.where}</span>
                <span class="vi26-aside-where-venue">{tDict(VENUE_I18N, e.venue)}</span>
                {e.address && <span class="vi26-aside-where-addr mono">{tDict(ADDR_I18N, e.address)}</span>}
                {e.mapUrl && (
                  <a class="vi26-aside-where-map mono" href={e.mapUrl} target="_blank" rel="noopener">
                    {LBL.map} <span aria-hidden="true">↗</span>
                  </a>
                )}
              </div>

              <dl class="vi26-aside-facts">
                {kind && (<><dt class="mono">{COPY.th_kind}</dt><dd>{kind}</dd></>)}
                {e.capacity && (
                  <><dt class="mono">{COPY.capacity_label}</dt><dd>{e.capacity} {COPY.seats_label}</dd></>
                )}
              </dl>

              {e.venueNote && (
                <p class="vi26-aside-note mono">{tEv(e, 'venueNote')}</p>
              )}

              <div class="vi26-event-cta">
                {e.eventbrite ? (
                  <a class="vi26-rsvp" href={e.eventbrite} target="_blank" rel="noopener">
                    <span class="vi26-arr">→</span> {COPY.rsvp}
                  </a>
                ) : (
                  <span class="vi26-rsvp is-soon">{COPY.seats_soon}</span>
                )}
                <p class="vi26-rsvp-note mono">{COPY.free_note}</p>
              </div>
            </div>
          </li>
        );
      })}
    </ol>
  </section>

  <!-- CARTEL -->
  <section class="vi26-cartel">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.cartel_n}</span>
      <h2 class="vi26-section-h">{COPY.cartel_h}</h2>
      <p class="vi26-section-sub">{COPY.cartel_sub}</p>
    </header>

    <ul class="vi26-cartel-list">
      {ARTISTS.map((a) => (
        <li class="vi26-cartel-row">
          <span class="vi26-cartel-name">{a.name}</span>
          <span class="vi26-cartel-role mono">{tDict(ROLE_I18N, a.role)}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- CALENDAR -->
  <section class="vi26-calendar">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.cal_n}</span>
      <h2 class="vi26-section-h">{COPY.cal_h}</h2>
      <p class="vi26-section-sub">{COPY.cal_sub}</p>
    </header>

    <div class="vi26-table-wrap">
      <table class="vi26-table">
        <thead>
          <tr>
            <th class="mono">{COPY.th_n}</th>
            <th class="mono">{COPY.th_date}</th>
            <th class="mono">{COPY.th_kind}</th>
            <th class="mono">{COPY.th_venue}</th>
            <th class="mono">{COPY.th_artists}</th>
            <th class="mono">{COPY.th_rsvp}</th>
          </tr>
        </thead>
        <tbody>
          {EVENTS.map((e) => e.rest ? (
            <tr class="is-tbc is-rest">
              <td class="mono vi26-td-n">—</td>
              <td class="mono"><span class="vi26-dow">{tDict(DOW_I18N, e.dow)}</span> {e.fullDate}</td>
              <td class="mono vi26-td-kind">{COPY.rest}</td>
              <td class="vi26-td-venue">—</td>
              <td class="mono">—</td>
              <td>—</td>
            </tr>
          ) : (
            <tr class={e.tbc ? 'is-tbc' : ''}>
              <td class="mono vi26-td-n">{e.n}</td>
              <td class="mono"><span class="vi26-dow">{tDict(DOW_I18N, e.dow)}</span> {e.fullDate}</td>
              <td class="mono vi26-td-kind">{(tEv(e, 'subtitle') as string)?.split('·')[0]?.trim() || tEv(e, 'title')}</td>
              <td class="vi26-td-venue">{tDict(VENUE_I18N, e.venue)}{e.municipality ? <span class="mono vi26-td-muni"> · {tDict(MUNI_I18N, e.municipality)}</span> : null}</td>
              <td class="mono">{e.artists.map((a) => a.name.split(' ')[0]).join(' · ')}</td>
              <td>
                {e.eventbrite ? (
                  <a class="vi26-rsvp-mini" href={e.eventbrite} target="_blank" rel="noopener">{COPY.rsvp} ↗</a>
                ) : (
                  <span class="vi26-rsvp-mini vi26-rsvp-soon mono">{COPY.soon}</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- INFO -->
  <section class="vi26-info">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.info_n}</span>
      <h2 class="vi26-section-h">{COPY.info_h}</h2>
      <p class="vi26-section-sub">{COPY.info_lede}</p>
    </header>

    <div class="vi26-info-grid">
      {COPY.info_blocks.map((b) => (
        <div class="vi26-info-block">
          <p class="vi26-info-eyebrow mono">{b.eyebrow}</p>
          <h3 class="vi26-info-h">{b.h}</h3>
          <p class="vi26-info-p">{b.p}</p>
        </div>
      ))}
    </div>

    <a class="vi26-cta vi26-cta-big" href={MAP_HREFS[lang]}>
      <span class="vi26-arr">→</span> {lang === 'en' ? 'See venue map' : 'Ver mapa de sedes'}
    </a>
  </section>

  <!-- FOLLOW -->
  <section class="vi26-follow">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.follow_n}</span>
      <h2 class="vi26-section-h">{COPY.follow_h}</h2>
      <p class="vi26-section-sub">{COPY.follow_sub}</p>
    </header>
    <div class="vi26-follow-actions">
      <a class="vi26-cta"
         href="mailto:leiguardamusic@gmail.com?subject=Bolet%C3%ADn%20Festival%20ADAR%202026&body=Hola%2C%20me%20gustar%C3%ADa%20recibir%20avisos%20del%20programa%202026.">
        <span class="vi26-arr">→</span> {COPY.follow_email}
      </a>
      <a class="vi26-cta vi26-cta-ghost" href="https://instagram.com/festivaladar" target="_blank" rel="noopener">
        <span class="vi26-arr">↗</span> {COPY.follow_ig}
      </a>
      <a class="vi26-cta vi26-cta-ghost" href="https://www.youtube.com/@festivaladar" target="_blank" rel="noopener">
        <span class="vi26-arr">↗</span> {COPY.follow_yt}
      </a>
    </div>
  </section>

  <!-- CREDITS -->
  <footer class="vi26-credits">
    <span class="vi26-section-n mono">{COPY.credits_n}</span>
    <h2 class="vi26-section-h">{COPY.credits_h}</h2>
    <dl class="vi26-credits-list">
      <dt class="mono">{COPY.curated}</dt>
      <dd>Guillermo Laporta · Josefina Urraca</dd>
      <dt class="mono">{COPY.produced}</dt>
      <dd>Asociación ADAR · Leiguarda, Belmonte de Miranda</dd>
      <dt class="mono">{COPY.supported}</dt>
      <dd>Principado de Asturias · Ayuntamientos anfitriones · partners institucionales y privados</dd>
    </dl>
    <p class="vi26-credits-foot mono">
      © 2026 ADAR · LEIGUARDA / BELMONTE DE MIRANDA · ASTURIES / ES
    </p>
  </footer>

</div>


</BaseLayout>
