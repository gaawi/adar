---

<BaseLayout
  title={COPY.title}
  lang={lang}
  permalink={`/${lang}/programa-2026/`}
  featuredImage={HERO_BG}
  bodyClass="vi26-body"
  translations={{
    es: '/es/programa-2026/',
    en: '/en/programa-2026/',
    ast: '/ast/programa-2026/',
  }}
>

<div class="vi26">

  <!-- TOP BAR -->
  <div class="vi26-topbar mono">
    <div class="vi26-topbar-track"><span>{COPY.topbar}</span><span>{COPY.topbar}</span><span>{COPY.topbar}</span></div>
  </div>

  <!-- HERO -->
  <section class="vi26-hero">
    <div class="vi26-hero-bg">
      <img src={HERO_BG} alt="ADAR Festival edición VI" loading="eager" />
    </div>
    <div class="vi26-hero-grain"></div>

    <div class="vi26-hero-meta">
      <span class="mono">{COPY.badge}</span>
      <span class="mono">{COPY.dates}</span>
      <span class="mono">{COPY.place}</span>
    </div>

    <div class="vi26-hero-six">VI</div>

    <div class="vi26-hero-body">
      <h1 class="vi26-hero-h">
        <span class="vi26-h-l1">{COPY.h_l1}</span>
        <span class="vi26-h-l2">{COPY.h_l2}</span>
        <span class="vi26-h-l3">{COPY.h_l3}</span>
      </h1>
      <p class="vi26-hero-sub">{COPY.sub}</p>
      <div class="vi26-hero-actions">
        <a class="vi26-cta" href="#glance">
          <span class="vi26-arr">↓</span> {COPY.rsvp_all}
        </a>
        <a class="vi26-cta vi26-cta-ghost"
           href="mailto:leiguardamusic@gmail.com?subject=Dosier%20de%20prensa%20Festival%20ADAR%202026">
          <span class="vi26-arr">→</span> {COPY.press}
        </a>
      </div>
    </div>
  </section>

  <!-- ARTIST TICKER -->
  <div class="vi26-ticker" aria-hidden="true">
    <div class="vi26-ticker-track">
      <span>{TICKER}{TICKER}{TICKER}</span>
    </div>
  </div>

  <!-- AT A GLANCE -->
  <section class="vi26-glance" id="glance">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.glance_n}</span>
      <h2 class="vi26-section-h">{COPY.glance_h}</h2>
      <p class="vi26-section-sub">{COPY.glance_sub}</p>
    </header>

    <div class="vi26-table-wrap">
      <table class="vi26-table">
        <thead>
          <tr>
            <th class="mono">{COPY.th_n}</th>
            <th class="mono">{COPY.th_date}</th>
            <th class="mono">{COPY.th_time}</th>
            <th class="mono">{COPY.th_kind}</th>
            <th class="mono">{COPY.th_venue}</th>
            <th class="mono">{COPY.th_muni}</th>
            <th class="mono">{COPY.th_rsvp}</th>
          </tr>
        </thead>
        <tbody>
          {NIGHTS.map((n) => (
            <tr class={n.confirmed ? '' : 'is-tbc'}>
              <td class="mono vi26-td-n">{n.n}</td>
              <td class="mono"><span class="vi26-dow">{n.dow}</span> {n.date}</td>
              <td class="mono">{n.time}</td>
              <td class="mono vi26-td-kind">{n.kind}</td>
              <td class="vi26-td-venue">{n.venue}</td>
              <td class="mono">{n.municipality}</td>
              <td>
                {n.eventbrite ? (
                  <a class="vi26-rsvp-mini" href={n.eventbrite} target="_blank" rel="noopener">{COPY.rsvp_short} ↗</a>
                ) : (
                  <span class="vi26-rsvp-mini vi26-rsvp-soon mono">{COPY.soon}</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- TWELVE NIGHTS GRID -->
  <section class="vi26-nights">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.nights_n}</span>
      <h2 class="vi26-section-h">{COPY.nights_h}</h2>
      <p class="vi26-section-sub">{COPY.nights_sub}</p>
    </header>

    <ol class="vi26-grid">
      {NIGHTS.map((n) => (
        <li class={`vi26-night vi26-night-${n.layout || 'square'} ${n.confirmed ? '' : 'is-tbc'}`}>
          <div class="vi26-night-media">
            <img src={n.image} alt={n.venue} loading="lazy" />
            <span class="vi26-night-n">{n.n}</span>
            <span class={`vi26-night-status mono ${n.confirmed ? '' : 'is-tbc'}`}>
              {n.confirmed ? COPY.confirmed : COPY.tbc}
            </span>
          </div>
          <div class="vi26-night-body">
            <div class="vi26-night-when mono">
              <span class="vi26-dow">{n.dow}</span> {n.date} · {n.time}
            </div>
            <p class="vi26-night-kind mono">{n.kind}</p>
            <h3 class="vi26-night-venue">{n.venue}</h3>
            <p class="vi26-night-muni mono">↳ {n.municipality}</p>
            <p class="vi26-night-curator">{n.curator}</p>

            <dl class="vi26-night-meta">
              <dt class="mono">{COPY.artists_label}</dt>
              <dd>
                {n.artists.map((a, i) => (
                  <span>{a}{i < n.artists.length - 1 ? ' · ' : ''}</span>
                ))}
              </dd>
              <dt class="mono">{COPY.program_label}</dt>
              <dd>
                <ul class="vi26-night-program">
                  {n.program.map((p) => <li>{p}</li>)}
                </ul>
              </dd>
            </dl>

            <div class="vi26-night-cta">
              {n.eventbrite ? (
                <a class="vi26-cta vi26-cta-small" href={n.eventbrite} target="_blank" rel="noopener">
                  <span class="vi26-arr">↗</span> {COPY.rsvp_short}
                </a>
              ) : (
                <span class="vi26-cta vi26-cta-small vi26-cta-disabled">{COPY.soon}</span>
              )}
            </div>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- ARTISTS WALL -->
  <section class="vi26-artists">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.artists_n}</span>
      <h2 class="vi26-section-h">{COPY.artists_h}</h2>
      <p class="vi26-section-sub">{COPY.artists_sub}</p>
    </header>

    <ul class="vi26-artists-grid">
      {ARTISTS.map((a) => (
        <li class="vi26-artist">
          <div class="vi26-artist-img">
            <img src={a.image} alt={a.name} loading="lazy" />
          </div>
          <div class="vi26-artist-meta">
            <p class="vi26-artist-role mono">{a.role}</p>
            <h3 class="vi26-artist-name">{a.name}</h3>
            <p class="vi26-artist-from mono">↳ {a.from}</p>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <!-- PRACTICAL INFO -->
  <section class="vi26-info">
    <header class="vi26-section-head">
      <span class="vi26-section-n mono">{COPY.info_n}</span>
      <h2 class="vi26-section-h">{COPY.info_h}</h2>
      <p class="vi26-section-sub">{COPY.info_lede}</p>
    </header>

    <div class="vi26-info-grid">
      {COPY.info_blocks.map((b) => (
        <div class="vi26-info-block">
          <p class="vi26-info-eyebrow mono">{b.eyebrow}</p>
          <h3 class="vi26-info-h">{b.h}</h3>
          <p class="vi26-info-p">{b.p}</p>
        </div>
      ))}
    </div>

    <a class="vi26-cta vi26-cta-big" href={MAP_HREFS[lang]}>
      <span class="vi26-arr">→</span> {lang === 'es' ? 'Ver mapa de sedes' : lang === 'ast' ? 'Ver mapa de sedes' : 'See venue map'}
    </a>
  </section>

  <!-- CREDITS -->
  <footer class="vi26-credits">
    <span class="vi26-section-n mono">{COPY.credits_n}</span>
    <h2 class="vi26-section-h">{COPY.credits_h}</h2>
    <dl class="vi26-credits-list">
      <dt class="mono">{COPY.curated}</dt>
      <dd>Guillermo Laporta · Josefina Urraca</dd>
      <dt class="mono">{COPY.produced}</dt>
      <dd>Asociación ADAR · Leiguarda, Belmonte de Miranda</dd>
      <dt class="mono">{COPY.supported}</dt>
      <dd>Principado de Asturias · Ayuntamientos anfitriones · Goethe-Institut · Reina Sofía · partners privados</dd>
    </dl>
    <p class="vi26-credits-foot mono">
      © 2026 ADAR · LEIGUARDA / BELMONTE DE MIRANDA · ASTURIES / ES
    </p>
  </footer>

</div>

</BaseLayout>
