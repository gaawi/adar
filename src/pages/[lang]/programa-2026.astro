    'clave':'harpsichord','violín':'violin','viola':'viola','violonchelo':'cello','flauta':'flute','piano':'piano','clarinete':'clarinet','poesía':'poetry',
    'voz, electrónica y creación sonora':'voice, electronics & sound creation',
    'guitarra, electrónica y creación sonora':'guitar, electronics & sound creation',
    'investigación artística y creación site-specific':'artistic research & site-specific creation',
    'Compositor residente':'Resident composer','Cinematógrafo':'Cinematographer',
  },
  ast: {
    'clave':'clave','violín':'violín','viola':'viola','violonchelo':'violonchelu','flauta':'flauta','piano':'pianu','clarinete':'clarinete','poesía':'poesía',
    'voz, electrónica y creación sonora':'voz, electrónica y creación sonora',
    'guitarra, electrónica y creación sonora':'guitarra, electrónica y creación sonora',
    'investigación artística y creación site-specific':'investigación artística y creación site-specific',
