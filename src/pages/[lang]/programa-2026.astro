    mapUrl: 'https://maps.app.goo.gl/dTvxzNexya2aE92J6',
    municipality: 'Belmonte de Miranda',
    photo: CDN + 'adar25fx30/DSC01590.jpg',
    memoriaSlug: 'recital-de-andrea-casarrubios-en-la-iglesia-de-leiguarda',
    memoriaYear: 2025,
    artists: [
      { name: 'Natania Hoffman',    role: 'violonchelo' },
      { name: 'Žilvinas Brazauskas', role: 'clarinete' },
      { name: 'Frederieke Saeijs',  role: 'violín' },
      { name: 'Guillermo Laporta',  role: 'flauta' },
