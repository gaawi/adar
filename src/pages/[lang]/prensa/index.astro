---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import type { Lang } from '../../../i18n/strings.ts';
import { LANGS } from '../../../i18n/strings.ts';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;

const COPY = {
  es: {
    title: 'Prensa',
    eyebrow: 'Festival ADAR · Hemeroteca',
    lede:
      'Cobertura del festival en medios locales, regionales y nacionales desde 2021. Todos los recortes, ordenados de más reciente a más antiguo.',
    read: 'Leer recorte',
    empty: 'Aún no hay artículos de prensa publicados.',
  },
  en: {
    title: 'Press',
    eyebrow: 'Festival ADAR · Archive',
    lede:
      'Coverage of the festival in local, regional and national media since 2021. Every cutting, sorted from latest to oldest.',
    read: 'Read cutting',
    empty: 'No press articles yet.',
  },
  ast: {
    title: 'Prensa',
    eyebrow: 'Festival ADAR · Hemeroteca',
    lede:
      'Cobertura del festival en medios locales, rexonales y nacionales dende 2021. Tolos recortes, axeitaos del más reciente al más antiguu.',
    read: 'Lleer recorte',
    empty: 'Entá nun hai artículos de prensa publicaos.',
  },
}[lang];

const allPosts = await getCollection('posts');
const items = allPosts
  .filter(
    (p) =>
      p.data.lang === lang &&
      p.data.status === 'publish' &&
      (p.data.categories || []).some((c) => /prensa|press/i.test(c)),
  )
  .sort(
    (a, b) =>
      (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

function fmtDate(d?: Date): string {
  if (!d) return '';
  return d.toLocaleDateString(lang === 'en' ? 'en-GB' : 'es-ES', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
  });
}

// Rotate clippings a little for the press-wall feel.
const tilts = ['-1.2deg', '0.8deg', '-0.4deg', '1.4deg', '-0.8deg', '0.6deg'];

const translations: Partial<Record<Lang, string>> = {
  es: '/es/prensa/',
  en: '/en/prensa/',
  ast: '/ast/prensa/',
};
---

<BaseLayout title={COPY.title} lang={lang} permalink={`/${lang}/prensa/`} translations={translations}>
  <section class="press-wall">
    <header class="press-wall-head">
      <span class="press-wall-eyebrow mono">{COPY.eyebrow}</span>
      <h1 class="press-wall-title">{COPY.title}<span class="press-wall-dot">.</span></h1>
      <p class="press-wall-lede">{COPY.lede}</p>
    </header>

    {items.length === 0 ? (
      <p class="press-wall-empty">{COPY.empty}</p>
    ) : (
      <ul class="press-wall-grid">
        {items.map((p, i) => (
          <li class="press-clip" style={`--tilt: ${tilts[i % tilts.length]}`}>
            <a href={p.data.permalink} class="press-clip-link">
              <span class="press-clip-tape" aria-hidden="true"></span>
              <header class="press-clip-mast">
                <span class="press-clip-outlet">{p.data.author}</span>
                <span class="press-clip-date mono">{fmtDate(p.data.date)}</span>
              </header>
              <h2 class="press-clip-title">{p.data.title}</h2>
              {p.data.excerpt && (
                <p class="press-clip-lede">{p.data.excerpt}</p>
              )}
              <span class="press-clip-cta mono">{COPY.read} →</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
