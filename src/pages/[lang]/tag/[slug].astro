---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import ArchiveBrowser from '../../../components/ArchiveBrowser.astro';
import type { Lang } from '../../../i18n/strings.ts';
import { LANGS } from '../../../i18n/strings.ts';
import { wpSlugify } from '../../../utils/slugify.ts';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const seen = new Set<string>();
  const paths: { params: { lang: Lang; slug: string }; props: any }[] = [];

  for (const lang of LANGS) {
    const tags = new Map<string, string>();
    posts
      .filter((p) => p.data.lang === lang)
      .forEach((p) => {
        for (const t of p.data.tags) {
          const slug = wpSlugify(t);
          if (slug) tags.set(slug, t);
        }
      });
    for (const [slug, name] of tags) {
      const key = `${lang}/${slug}`;
      if (seen.has(key)) continue;
      seen.add(key);
      paths.push({ params: { lang, slug }, props: { name } });
    }
  }
  return paths;
}

interface Props {
  name: string;
}
const { name } = Astro.props;
const lang = Astro.params.lang as Lang;
const slug = Astro.params.slug as string;

const allPosts = await getCollection('posts');
const items = allPosts
  .filter((p) => p.data.lang === lang && p.data.status === 'publish')
  .filter((p) =>
    p.data.tags.some((t) => wpSlugify(t) === slug),
  )
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));

const titleByLang = {
  es: `Etiqueta: ${name}`,
  en: `Tag: ${name}`,
  ast: `Etiqueta: ${name}`,
}[lang];

const eyebrowByLang = {
  es: 'Festival ADAR · Etiqueta',
  en: 'Festival ADAR · Tag',
  ast: 'Festival ADAR · Etiqueta',
}[lang];

const ledeByLang = {
  es: `${items.length} publicaciones con esta etiqueta.`,
  en: `${items.length} entries with this tag.`,
  ast: `${items.length} publicaciones con esta etiqueta.`,
}[lang];

const heroImage = items[0]?.data.featured_image;
---

<BaseLayout title={titleByLang} lang={lang} permalink={`/${lang}/tag/${slug}/`}>
  <Hero eyebrow={eyebrowByLang} title={name} lede={ledeByLang} image={heroImage} />
  <ArchiveBrowser items={items} lang={lang} />
</BaseLayout>
