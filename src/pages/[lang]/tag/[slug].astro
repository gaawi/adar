---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import ArchiveBrowser from '../../../components/ArchiveBrowser.astro';
import type { Lang } from '../../../i18n/strings.ts';
import { LANGS } from '../../../i18n/strings.ts';
import { wpSlugify } from '../../../utils/slugify.ts';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const seen = new Set<string>();
  const paths: { params: { lang: Lang; slug: string }; props: any }[] = [];

  for (const lang of LANGS) {
    const tags = new Map<string, string>();
    posts
      .filter((p) => p.data.lang === lang)
      .forEach((p) => {
        for (const t of p.data.tags) {
          const slug = wpSlugify(t);
          if (slug) tags.set(slug, t);
        }
      });
    for (const [slug, name] of tags) {
      const key = `${lang}/${slug}`;
      if (seen.has(key)) continue;
      seen.add(key);
      paths.push({ params: { lang, slug }, props: { name } });
    }
  }
  return paths;
}

interface Props {
  name: string;
}
const { name } = Astro.props;
const lang = Astro.params.lang as Lang;
const slug = Astro.params.slug as string;

const allPosts = await getCollection('posts');
const rawItems = allPosts
  .filter((p) => p.data.lang === lang && p.data.status === 'publish')
  .filter((p) =>
    p.data.tags.some((t) => wpSlugify(t) === slug),
  )
  .filter((p) => !(p.data.categories || []).some((c) => /prensa|press/i.test(c)))
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));

function extractImages(body: string, featured?: string): string[] {
  const urls: string[] = [];
  const seen = new Set<string>();
  if (featured) { urls.push(featured); seen.add(featured); }
  const re = /<img[^>]+src=["']([^"']+)["']/gi;
  let m: RegExpExecArray | null;
  while ((m = re.exec(body)) !== null) {
    const u = m[1];
    if (!seen.has(u)) { urls.push(u); seen.add(u); }
  }
  return urls;
}

const items = rawItems.map((p) => ({
  data: p.data,
  images: extractImages(p.body ?? '', p.data.featured_image),
}));

const titleByLang = {
  es: `Etiqueta: ${name}`,
  en: `Tag: ${name}`,
  ast: `Etiqueta: ${name}`,
}[lang];

const eyebrowByLang = {
  es: 'Festival ADAR · Etiqueta',
  en: 'Festival ADAR · Tag',
  ast: 'Festival ADAR · Etiqueta',
}[lang];

const ledeByLang = {
  es: `${items.length} publicaciones con esta etiqueta.`,
  en: `${items.length} entries with this tag.`,
  ast: `${items.length} publicaciones con esta etiqueta.`,
}[lang];

const heroImage = items[0]?.data.featured_image;

// Tag slugs are language-specific (a "concierto" tag has no "concierto"
// page in EN). Only offer the switcher for languages where THIS exact tag
// slug actually exists; otherwise send the visitor to that language's
// archive index so the switcher never points at a missing page.
const ARCHIVE_HREF: Record<Lang, string> = {
  es: '/es/category/memoria-de-acciones/',
  en: '/en/category/projects-archive/',
  ast: '/ast/category/memoria-dacciones/',
};
const tagSlugsByLang: Record<string, Set<string>> = {};
for (const l of LANGS as Lang[]) {
  const set = new Set<string>();
  allPosts
    .filter((p) => p.data.lang === l && p.data.status === 'publish')
    .forEach((p) => p.data.tags.forEach((t) => { const s = wpSlugify(t); if (s) set.add(s); }));
  tagSlugsByLang[l] = set;
}
const translations: Partial<Record<Lang, string>> = Object.fromEntries(
  (LANGS as Lang[]).map((l) => [
    l,
    l === lang || tagSlugsByLang[l].has(slug) ? `/${l}/tag/${slug}/` : ARCHIVE_HREF[l],
  ]),
);
---

<BaseLayout
  title={titleByLang}
  lang={lang}
  permalink={`/${lang}/tag/${slug}/`}
  translations={translations}
>
  <Hero eyebrow={eyebrowByLang} title={name} lede={ledeByLang} image={heroImage} />
  <ArchiveBrowser items={items} lang={lang} />
</BaseLayout>
