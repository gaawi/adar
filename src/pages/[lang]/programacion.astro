---
import type { Lang } from '../../i18n/strings.ts';
import { LANGS } from '../../i18n/strings.ts';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
// La programación principal redirige a la edición en curso (VI · 2026).
// Las ediciones pasadas viven en /programacion-archivo/.
return Astro.redirect(`/${lang}/programa-2026/`, 302);
---
