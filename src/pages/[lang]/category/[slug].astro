---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import ArchiveBrowser from '../../../components/ArchiveBrowser.astro';
import type { Lang } from '../../../i18n/strings.ts';
import { LANGS } from '../../../i18n/strings.ts';
import { wpSlugify } from '../../../utils/slugify.ts';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const seen = new Set<string>();
  const paths: { params: { lang: Lang; slug: string }; props: any }[] = [];

  for (const lang of LANGS) {
    const cats = new Map<string, string>();
    posts
      .filter((p) => p.data.lang === lang)
      .forEach((p) => {
        for (const c of p.data.categories) {
          const slug = wpSlugify(c);
          if (slug) cats.set(slug, c);
        }
      });
    for (const [slug, name] of cats) {
      const key = `${lang}/${slug}`;
      if (seen.has(key)) continue;
      seen.add(key);
      paths.push({ params: { lang, slug }, props: { name } });
    }
  }
  return paths;
}

interface Props {
  name: string;
}
const { name } = Astro.props;
const lang = Astro.params.lang as Lang;
const slug = Astro.params.slug as string;

const allPosts = await getCollection('posts');
const rawItems = allPosts
  .filter((p) => p.data.lang === lang && p.data.status === 'publish')
  .filter((p) =>
    p.data.categories.some((c) => wpSlugify(c) === slug),
  )
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));

function extractImages(body: string, featured?: string): string[] {
  const urls: string[] = [];
  const seen = new Set<string>();
  if (featured) {
    urls.push(featured);
    seen.add(featured);
  }
  const re = /<img[^>]+src=["']([^"']+)["']/gi;
  let m: RegExpExecArray | null;
  while ((m = re.exec(body)) !== null) {
    const u = m[1];
    if (!seen.has(u)) {
      urls.push(u);
      seen.add(u);
    }
  }
  return urls;
}

const items = rawItems.map((p) => ({
  data: p.data,
  images: extractImages(p.body ?? '', p.data.featured_image),
}));

const isMemoria = slug === 'memoria-de-acciones' || slug === 'projects-archive' || slug === 'memoria-dacciones';

const titleByLang = {
  es: `Categoría: ${name}`,
  en: `Category: ${name}`,
  ast: `Categoría: ${name}`,
}[lang];

const eyebrowByLang = {
  es: 'Festival ADAR · Categoría',
  en: 'Festival ADAR · Category',
  ast: 'Festival ADAR · Categoría',
}[lang];

const ledeByLang = {
  es: `${items.length} publicaciones en esta categoría.`,
  en: `${items.length} entries in this category.`,
  ast: `${items.length} publicaciones nesta categoría.`,
}[lang];

const heroImage = items[0]?.data.featured_image;

// Known category slug mappings across the three languages, so the
// header language switcher lands on the equivalent category page
// instead of falling back to the home.
const CATEGORY_MAP: Record<string, Record<Lang, string>> = {
  'memoria-de-acciones': { es: 'memoria-de-acciones', en: 'projects-archive', ast: 'memoria-dacciones' },
  'projects-archive':   { es: 'memoria-de-acciones', en: 'projects-archive', ast: 'memoria-dacciones' },
  'memoria-dacciones':  { es: 'memoria-de-acciones', en: 'projects-archive', ast: 'memoria-dacciones' },
  'prensa': { es: 'prensa', en: 'prensa', ast: 'prensa' },
  'press':  { es: 'prensa', en: 'prensa', ast: 'prensa' },
};
const ARCHIVE_HREF: Record<Lang, string> = {
  es: '/es/category/memoria-de-acciones/',
  en: '/en/category/projects-archive/',
  ast: '/ast/category/memoria-dacciones/',
};
const mapped = CATEGORY_MAP[slug];
const translations: Partial<Record<Lang, string>> = mapped
  ? Object.fromEntries(
      (LANGS as Lang[]).map((l) => [l, `/${l}/category/${mapped[l]}/`]),
    )
  // Unmapped categories (e.g. "uncategorized") have no guaranteed
  // counterpart: keep the current language on its page and send the others
  // to their archive index rather than a missing same-slug category.
  : Object.fromEntries(
      (LANGS as Lang[]).map((l) => [l, l === lang ? `/${lang}/category/${slug}/` : ARCHIVE_HREF[l]]),
    );
---

<BaseLayout
  title={titleByLang}
  lang={lang}
  permalink={`/${lang}/category/${slug}/`}
  translations={translations}
>
  {!isMemoria && (
    <Hero eyebrow={eyebrowByLang} title={name} lede={ledeByLang} image={heroImage} />
  )}
  <ArchiveBrowser items={items} lang={lang} variant={isMemoria ? 'memoria' : 'default'} />
</BaseLayout>
