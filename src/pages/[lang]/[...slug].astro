---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Home from '../../components/home/Home.astro';
import Hero from '../../components/Hero.astro';
import Contact from '../../components/Contact.astro';
import type { Lang } from '../../i18n/strings.ts';
import { LANGS } from '../../i18n/strings.ts';

type AnyEntry =
  | (CollectionEntry<'pages'> & { collection: 'pages' })
  | (CollectionEntry<'posts'> & { collection: 'posts' });

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  const posts = await getCollection('posts');
  const all: AnyEntry[] = [...pages, ...posts];

  return all
    .filter((e) => e.data.status === 'publish')
    .map((entry) => {
      const lang = entry.data.lang as Lang;
      const permalink = entry.data.permalink || `/${lang}/${entry.data.slug}/`;
      // Strip leading /{lang}/ and trailing /
      let slug = permalink.replace(new RegExp(`^/${lang}/?`), '');
      slug = slug.replace(/\/$/, '');
      return {
        params: { lang, slug },
        props: { entry },
      };
    });
}

interface Props {
  entry: AnyEntry;
}
const { entry } = Astro.props;
const lang = entry.data.lang as Lang;
const { Content } = await render(entry);

// Pull eyebrow and lede out of the legacy hero blocks living inside the
// markdown body so the new unified Hero keeps the original copy. The old
// inline heroes themselves are hidden by CSS.
const body = (entry.body ?? '') as string;
function pluck(re: RegExp): string | undefined {
  const m = body.match(re);
  if (!m) return undefined;
  return m[1].replace(/\s+/g, ' ').trim() || undefined;
}
const ampEyebrow = pluck(/<span class="amp-eyebrow">([\s\S]*?)<\/span>/);
const ampSubtitle = pluck(/<p class="amp-subtitle">([\s\S]*?)<\/p>/);
const archEyebrow = pluck(/<span class="adar-archive-eyebrow">([\s\S]*?)<\/span>/);
const archLede = pluck(/<p class="adar-archive-lede">([\s\S]*?)<\/p>/);
const heroEyebrow = ampEyebrow || archEyebrow || 'Festival ADAR';
const heroLede = entry.data.excerpt || ampSubtitle || archLede;

// Build translation map by translation_group
const group = entry.data.translation_group;
let translations: Partial<Record<Lang, string>> = {};
if (group) {
  const all = [...(await getCollection('pages')), ...(await getCollection('posts'))];
  all.forEach((e) => {
    if (e.data.translation_group === group && LANGS.includes(e.data.lang as Lang)) {
      translations[e.data.lang as Lang] = e.data.permalink;
    }
  });
}

const isHome = entry.data.permalink === `/${lang}/adar/` ||
               entry.data.permalink === `/${lang}/adar-festival/` ||
               entry.data.permalink === `/${lang}/festival-adar/`;

const isPost = entry.collection === 'posts';
const isPress = (entry.data.categories || []).some((c) =>
  /prensa|press/i.test(c),
);
const isContact =
  entry.data.permalink === `/${lang}/contacto/` ||
  entry.data.permalink === `/${lang}/contact/` ||
  entry.data.permalink === `/${lang}/contautu/`;
const bodyClasses = [
  isPost ? 'single single-post' : 'page',
  isHome
    ? 'home page-template page-template-full-width-transparent inspiro-front-page'
    : '',
  isPress ? 'is-press' : '',
  isContact ? 'is-contact' : '',
  'has-header-image',
  `page-id-${entry.data.wp_id || ''}`,
]
  .filter(Boolean)
  .join(' ');
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.excerpt || 'Festival ADAR'}
  lang={lang}
  permalink={entry.data.permalink}
  featuredImage={entry.data.featured_image}
  translations={translations}
  bodyClass={bodyClasses}
>
  {!isHome && !isPress && !isContact && (
    <Hero
      eyebrow={heroEyebrow}
      title={entry.data.title}
      lede={heroLede}
      image={entry.data.featured_image}
      variant={entry.collection === 'posts' ? 'banner' : 'overlay'}
    />
  )}
  <div class="builder-wrap full-width">
    <article id={`post-${entry.data.wp_id || ''}`} class={`post-${entry.data.wp_id || ''} ${entry.collection === 'pages' ? 'page' : 'post'} type-${entry.collection === 'pages' ? 'page' : 'post'} status-publish hentry`}>
      <div class="entry-content">
        {isHome ? <Home lang={lang} /> : isContact ? <Contact lang={lang} /> : <Content />}
      </div>
    </article>
  </div>
</BaseLayout>
