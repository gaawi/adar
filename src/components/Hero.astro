---
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  image?: string;
  variant?: 'overlay' | 'banner';
}
const {
  eyebrow = 'Festival ADAR',
  title,
  lede,
  image,
  variant = 'overlay',
} = Astro.props;

const fallback = 'https://creartbox-media-cdn.b-cdn.net/adarimages/adar25fx30/DSC01841.jpg';
const heroImage = image || fallback;
---

<section class={`page-hero page-hero--${variant}`}>
  <div class="page-hero-img" aria-hidden="true">
    <img src={heroImage} alt="" />
  </div>

  {variant === 'overlay' && (
    <div class="page-hero-veil" aria-hidden="true"></div>
  )}

  {variant === 'overlay' && (
    <div class="page-hero-inner">
      {eyebrow && <span class="page-hero-eyebrow">{eyebrow}</span>}
      <h1 class="page-hero-title">
        {title}<span class="page-hero-dot">.</span>
      </h1>
      {lede && <p class="page-hero-lede">{lede}</p>}
    </div>
  )}

  {variant === 'banner' && (
    <div class="page-hero-banner">
      <div class="page-hero-banner-strip" aria-hidden="true"></div>
      <div class="page-hero-banner-inner">
        {eyebrow && <span class="page-hero-banner-eyebrow">{eyebrow}</span>}
        <h1 class="page-hero-banner-title">
          {title}<span class="page-hero-dot">.</span>
        </h1>
        {lede && <p class="page-hero-banner-lede">{lede}</p>}
      </div>
    </div>
  )}
</section>
