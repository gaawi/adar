---

<div class="hm">
  <!-- Sticky side banner (desktop only) — anuncia la programación VI · 2026 -->
  <aside class="hm-side-banner" aria-label="Programación 2026 disponible">
    <a class="hm-side-banner-link" href={`/${lang}/programa-2026/`}>
      <span class="hm-side-banner-pulse" aria-hidden="true"></span>
      <span class="hm-side-banner-eyebrow mono">Programa 2026</span>
      <span class="hm-side-banner-h">Ya disponible</span>
      <span class="hm-side-banner-sub mono">4 — 16 agosto · once conciertos</span>
      <span class="hm-side-banner-cta mono">Ver programa <span aria-hidden="true">→</span></span>
    </a>
  </aside>

  <!-- ============================================
       HERO · acto inaugural
       ============================================ -->
  <section class="hm-hero">
    <div class="hm-hero-img">
      <img src={heroImage} alt="Festival ADAR" />
    </div>
    <div class="hm-hero-veil"></div>

    <div class="hm-hero-meta">
      <span class="hm-hero-meta-l">{COPY.eyebrow}</span>
      <span class="hm-hero-meta-r mono">
        43.2° N · 6.2° W
      </span>
    </div>

    <div class="hm-hero-body">
      <h1 class="hm-hero-title">
        <span class="hm-hero-l1">{COPY.title1}</span>
        <span class="hm-hero-l2"><em>{COPY.title2}</em></span>
        <span class="hm-hero-l3">{COPY.title3}<span class="hm-dot">.</span></span>
      </h1>
      <p class="hm-hero-lede">{COPY.lede}</p>
    </div>

    <div class="hm-hero-foot">
      <a href="#video" class="hm-hero-watch">
        <span class="hm-play" aria-hidden="true"></span>
        {COPY.watchVideo}
      </a>
      <span class="hm-scroll mono">↓ {COPY.scrollHint}</span>
    </div>

    <div class="hm-marquee" aria-hidden="false">
      <div class="hm-marquee-track">
        {COPY.marquee.map((place, i) => (
          <span class="hm-marquee-item">
            <span class="hm-marquee-num mono">{String(i + 1).padStart(2, '0')}</span>
            {place}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       § ANUNCIO · Edición VI · 2026
       ============================================ -->
  <section class="hm-adar26" id="adar26" aria-labelledby="adar26-h">
    <div class="hm-adar26-wrap">
      <header class="hm-adar26-head">
        <span class="hm-adar26-tag mono">{ADAR26_COPY.eyebrow}</span>
        <span class="hm-adar26-dates mono">{ADAR26_COPY.dates}</span>
      </header>

      <div class="hm-adar26-grid">
        <div class="hm-adar26-left">
          <a class="hm-adar26-poster" href={ADAR26_HREF} aria-label={ADAR26_COPY.cta_program}>
            <img src={ADAR26_POSTER} alt="Cartel oficial Festival ADAR 2026" loading="lazy" />
          </a>

          <h2 class="hm-adar26-h" id="adar26-h">
            {ADAR26_COPY.title_pre} <em>{ADAR26_COPY.title_year}</em>
          </h2>
          <p class="hm-adar26-lede">{ADAR26_COPY.tag}</p>
          <p class="hm-adar26-sub">{ADAR26_COPY.sub}</p>

          <div class="hm-adar26-ctas">
            <a class="hm-adar26-cta" href={ADAR26_HREF}>
              <span aria-hidden="true">→</span>
              {ADAR26_COPY.cta_program}
            </a>
            <a class="hm-adar26-cta hm-adar26-cta-ghost"
               href={ADAR26_PRESS_HREF}>
              <span aria-hidden="true">↗</span>
              {ADAR26_COPY.cta_press}
            </a>
          </div>
        </div>

        <div class="hm-adar26-right">
          <p class="hm-adar26-ix-label mono">{ADAR26_COPY.ix_label}</p>
          <ol class="hm-adar26-list">
            {ADAR26.map((e) => (
              <li class="hm-adar26-row">
                <a class="hm-adar26-link" href={`${ADAR26_HREF}#event-${e.n}`}>
                  <span class="hm-adar26-thumb">
                    <img src={e.photo} alt="" loading="lazy" />
                  </span>
                  <span class="hm-adar26-n mono">{e.n}</span>
                  <span class="hm-adar26-when mono">
                    <span class="hm-adar26-dow">{e.dow}</span>
                    <span class="hm-adar26-date">{e.date}</span>
                    {e.time && <span class="hm-adar26-time">{e.time}h</span>}
                  </span>
                  <span class="hm-adar26-body">
                    <span class="hm-adar26-kind">{e.title}</span>
                    <span class="hm-adar26-venue mono">{e.venue} · {e.muni}</span>
                  </span>
                </a>
              </li>
            ))}
          </ol>
          <p class="hm-adar26-free mono">{ADAR26_COPY.free}</p>
          <p class="hm-adar26-note mono">↳ {ADAR26_COPY.credits}</p>
          <p class="hm-adar26-note mono">↳ {ADAR26_COPY.horreo_note}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       § 01 VIDEO MANIFESTO
       ============================================ -->
  <section class="hm-video" id="video">
    <header class="hm-section-head">
      <span class="hm-eyebrow">{COPY.video_eyebrow}</span>
    </header>
    <div class="hm-video-wrap">
      <h2 class="hm-h2 hm-h2-light">{COPY.video_h}</h2>
      <p class="hm-video-lede">{COPY.video_lede}</p>
      <div class="hm-video-frame">
        <iframe
          src="https://iframe.mediadelivery.net/embed/449741/19a562fd-a1b7-4179-9781-d15788c5ced0?autoplay=false&loop=false&muted=false&preload=false&responsive=true"
          loading="lazy"
          allow="accelerometer;gyroscope;autoplay;encrypted-media;picture-in-picture;"
          allowfullscreen="true"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- ============================================
       § 02 COORDENADAS
       ============================================ -->
  <section class="hm-coord">
    <header class="hm-section-head">
      <span class="hm-eyebrow">{COPY.coord_eyebrow}</span>
    </header>
    <div class="hm-coord-grid">
      <div class="hm-coord-lede">
        <h2 class="hm-h2">{COPY.coord_h}</h2>
        <p>{COPY.coord_lede}</p>
      </div>

      <dl class="hm-specs">
        <p class="hm-specs-title mono">{COPY.coord_specsTitle}</p>
        {COPY.coord_specs.map(([k, v]) => (
          <div class="hm-spec">
            <dt class="mono">{k}</dt>
            <dd>{v}</dd>
          </div>
        ))}
      </dl>

      <div class="hm-stats">
        <p class="hm-specs-title mono">{COPY.statsTitle}</p>
        <div class="hm-stats-grid">
          {COPY.stats.map(([n, l]) => (
            <div class="hm-stat">
              <span class="hm-stat-n">{n}</span>
              <span class="hm-stat-l mono">{l}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       § 02 ÍNDICE DE ACCIONES
       ============================================ -->
  <section class="hm-index">
    <header class="hm-section-head">
      <span class="hm-eyebrow">{COPY.index_eyebrow}</span>
      <div class="hm-section-head-r">
        <h2 class="hm-h2">{COPY.index_h}</h2>
        <p class="hm-section-lede">{COPY.index_lede}</p>
      </div>
    </header>

    <ol class="hm-index-list">
      {featured.map((p, i) => {
        const tags = p.data.tags || [];
        const year = yearOf(tags);
        const place = placeOf(tags);
        const discipline = disciplineOf(tags);
        const num = String(i + 1).padStart(3, '0');
        return (
          <li class="hm-card" style={`--i:${i}`}>
            <a href={p.data.permalink} class="hm-card-link">
              <div class="hm-card-img">
                <img src={p.data.featured_image} alt={p.data.title} loading="lazy" />
              </div>
              <div class="hm-card-meta mono">
                <span class="hm-card-num">№ {num}</span>
                <span class="hm-card-year">{year}</span>
              </div>
              <h3 class="hm-card-title">{p.data.title}</h3>
              <div class="hm-card-foot mono">
                {place && <span>{place}</span>}
                {place && discipline && <span class="hm-card-sep">·</span>}
                {discipline && <span>{discipline}</span>}
                <span class="hm-card-arr">→</span>
              </div>
            </a>
          </li>
        );
      })}
    </ol>

    <div class="hm-index-swipe" aria-hidden="true">
      <span class="hm-index-swipe-bar"></span>
      <span>Swipe →</span>
    </div>

    <a class="hm-index-cta" href={ARCHIVE_HREF[lang]}>
      <span class="hm-arr">→</span>
      {COPY.index_cta}
    </a>
  </section>

  <!-- ============================================
       § 04 SEIS PRINCIPIOS
       ============================================ -->
  <section class="hm-principles">
    <div class="hm-principles-inner">
      <aside class="hm-principles-side">
        <img
          src="https://creartbox-media-cdn.b-cdn.net/adarimages/adar25fx30/C1981T01.jpg"
          alt="Festival ADAR · Leiguarda"
          loading="lazy"
        />
        <span class="hm-principles-side-cap mono">{COPY.principles_eyebrow}</span>
      </aside>
      <div class="hm-principles-main">
        <span class="hm-eyebrow">{COPY.principles_eyebrow}</span>
        <h2 class="hm-h2 hm-principles-h">{COPY.principles_h}</h2>
        <p class="hm-section-lede hm-principles-lede">{COPY.principles_lede}</p>
        <ol class="hm-principles-list">
          {COPY.principles.map((item, i) => {
            const [h, d, paragraphs] = item as [string, string, string[]?];
            const hasDetail = !!(paragraphs && paragraphs.length > 0);
            return (
              <li class="hm-principle">
                {hasDetail ? (
                  <details class="hm-principle-toggle">
                    <summary class="hm-principle-summary">
                      <span class="hm-principle-n mono">0{i + 1}</span>
                      <span class="hm-principle-summary-text">
                        <span class="hm-principle-h">{h}<span class="hm-dot">.</span></span>
                        <span class="hm-principle-d">{d}</span>
                      </span>
                      <span class="hm-principle-chevron" aria-hidden="true">+</span>
                    </summary>
                    <div class="hm-principle-detail">
                      {paragraphs!.map((para) => <p>{para}</p>)}
                    </div>
                  </details>
                ) : (
                  <div class="hm-principle-static">
                    <span class="hm-principle-n mono">0{i + 1}</span>
                    <span class="hm-principle-summary-text">
                      <span class="hm-principle-h">{h}<span class="hm-dot">.</span></span>
                      <span class="hm-principle-d">{d}</span>
                    </span>
                  </div>
                )}
              </li>
            );
          })}
        </ol>
      </div>
    </div>
  </section>

  <!-- ============================================
       § 05 PRENSA
       ============================================ -->
  <section class="hm-press">
    <header class="hm-section-head">
      <span class="hm-eyebrow">{COPY.press_eyebrow}</span>
      <h2 class="hm-h2">{COPY.press_h}</h2>
    </header>
    <ul class="hm-press-list">
      {COPY.press.map((row) => {
        const [d, src, t, href] = row as [string, string, string, string?];
        const Row = href ? 'a' : 'span';
        return (
          <li class="hm-press-row">
            <Row class={href ? 'hm-press-row-link' : ''} href={href}>
              <span class="hm-press-date mono">{d}</span>
              <span class="hm-press-src mono">{src}</span>
              <span class="hm-press-title">{t}</span>
              {href && <span class="hm-press-arr">→</span>}
            </Row>
          </li>
        );
      })}
    </ul>
  </section>

  <!-- ============================================
       § 06 CÍRCULO / COMUNIDAD
       ============================================ -->
  <section class="hm-join">
    <div class="hm-join-bg" aria-hidden="true">
      <img src={joinBg} alt="" />
    </div>
    <svg class="hm-join-ring" viewBox="0 0 800 800" aria-hidden="true">
      <circle cx="400" cy="400" r="380" fill="none" stroke="currentColor" stroke-width="1" />
      <circle cx="400" cy="400" r="320" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="2 6" />
      <circle cx="400" cy="400" r="260" fill="none" stroke="currentColor" stroke-width="1" />
    </svg>
    <div class="hm-join-body">
      <span class="hm-eyebrow hm-eyebrow-light">{COPY.join_eyebrow}</span>
      <h2 class="hm-join-h">
        {COPY.join_h_a} <em>{COPY.join_h_b}</em> {COPY.join_h_c}
      </h2>
      <p class="hm-join-lede">{COPY.join_lede}</p>
      <div class="hm-join-ctas">
        <a class="hm-join-cta" href={CONTACT_HREF[lang]}>
          <span class="hm-arr">→</span>
          {COPY.join_cta_email}
        </a>
        <a class="hm-join-cta" href="https://instagram.com/festivaladar" target="_blank" rel="noopener">
          <span class="hm-arr">→</span>
          {COPY.join_cta_ig}
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       FOOTER · monumento
       ============================================ -->
  <section class="hm-monument">
    <div class="hm-monument-meta">
      <span class="mono">{COPY.footer_eyebrow}</span>
      <span class="mono">{COPY.footer_date}</span>
    </div>
    <h2 class="hm-monument-h">
      <span>{COPY.footer_h_a}</span>
      <span><em>{COPY.footer_h_b}</em></span>
      <span>{COPY.footer_h_c}<span class="hm-dot">.</span></span>
    </h2>
    <div class="hm-monument-ctas">
      <a href={CONTACT_HREF[lang]}>{COPY.footer_cta_a}<span class="hm-arr">↗</span></a>
      <a href={TEAM_HREF[lang]}>{COPY.footer_cta_b}<span class="hm-arr">↗</span></a>
      <a href={MAP_HREF[lang]}>{COPY.footer_cta_c}<span class="hm-arr">↗</span></a>
    </div>

    <div class="hm-funders">
      <span class="hm-eyebrow hm-eyebrow-light">{COPY.funders_eyebrow}</span>
      <ul class="hm-funders-row">
        {FUNDERS.map((f) => (
          <li>
            <a href={f.href} target="_blank" rel="noopener" aria-label={f.name}>
              <img src={f.logo} alt={f.name} loading="lazy" />
            </a>
          </li>
        ))}
      </ul>
    </div>

    <p class="hm-colophon mono">{COPY.colophon}</p>
  </section>
</div>
