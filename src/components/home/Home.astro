  { n: '11', date: '16 ago', time: '21:30', photo: 'https://creartbox-media-cdn.b-cdn.net/adarimages/adar25fx30/DSC01590.jpg',
    dow: { es: 'Dom', en: 'Sun', ast: 'Dom' },
    title: { es: 'Clausura · Quinteto y espicha', en: 'Closing · Quintet & espicha', ast: 'Zarru · Quintetu y espicha' },
    venue: { es: 'Iglesia de Leiguarda', en: 'Church of Leiguarda', ast: 'Ilesia de Lleiguarda' },
