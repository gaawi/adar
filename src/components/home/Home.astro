import { getCollection } from 'astro:content';
import type { Lang } from '../../i18n/strings.ts';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const ARCHIVE_CATEGORY: Record<Lang, string> = {
  es: 'Memoria de Acciones',
  en: 'Projects Archive',
  ast: 'Memoria d’Acciones',
};

const ARCHIVE_HREF: Record<Lang, string> = {
  es: '/es/category/memoria-de-acciones/',
  en: '/en/category/projects-archive/',
  ast: '/ast/category/memoria-de-acciones/',
};

const CONTACT_HREF: Record<Lang, string> = {
  es: '/es/contacto/',
  en: '/en/contact/',
  ast: '/ast/contautu/',
};

const TEAM_HREF: Record<Lang, string> = {
  es: '/es/equipo/',
  en: '/en/team/',
  ast: '/ast/equipu/',
};

const MAP_HREF: Record<Lang, string> = {
  es: '/es/mapa-de-acciones/',
  en: '/en/map-of-actions/',
  ast: '/ast/mapa-acciones/',
};

const posts = await getCollection('posts');
const archive = posts
  .filter(
    (p) =>
      p.data.lang === lang &&
      p.data.status === 'publish' &&
      p.data.categories?.includes(ARCHIVE_CATEGORY[lang]) &&
      p.data.featured_image,
  )
  .sort(
    (a, b) =>
      (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
  );

const featured = archive.slice(0, 6);

function yearOf(tags: string[]): string {
  return tags.find((t) => /^20\d{2}$/.test(t)) ?? '';
}

function placeOf(tags: string[]): string {
  const ignore = new Set([
    'concierto', 'concert', 'conciertu',
    'música de cámara', 'chamber music', 'música cámara',
    'instalación', 'installation', 'instalación sonora',
    'aire libre', 'open air',
    'lugar emblemático', 'landmark',
    'sound walk', 'paseo sonoro',
    'video', 'vídeo', 'videoarte',
  ]);
  const place = tags.find(
    (t) => !/^20\d{2}$/.test(t) && !ignore.has(t.toLowerCase()),
  );
  return place ?? '';
}

function disciplineOf(tags: string[]): string {
  const disciplines = [
    'concierto', 'concert', 'conciertu',
    'instalación', 'installation',
    'sound walk', 'paseo sonoro',
    'videoarte', 'video art',
    'residencia', 'residency',
  ];
  return tags.find((t) => disciplines.includes(t.toLowerCase())) ?? '';
}

