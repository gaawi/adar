const ADAR26_HREF = `/${lang}/programa-2026/`;
const ADAR26_PRESS_HREF = {
  es:  '/es/nota-de-prensa-adar-2026/',
  en:  '/en/press-release-adar-2026/',
  ast: '/ast/nota-de-prensa-adar-2026/',
}[lang];
const ADAR26_COPY = {
  es: {
    eyebrow: 'Próxima edición · Edición VI',
    dates: '4 — 16 agosto 2026',
    title_pre: 'Festival ADAR',
    title_year: '2026',
    tag: 'Festival para el desarrollo de las artes en el medio rural.',
    sub: 'Once conciertos del 4 al 16 de agosto en siete sedes patrimoniales de Asturias. Música de cámara, intervenciones site-specific en Leiguarda y un cierre con espicha.',
