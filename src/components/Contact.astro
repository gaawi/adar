---

<section class="ct">
  <!-- Hero typographic — no image -->
  <header class="ct-head">
    <span class="ct-eyebrow">{COPY.eyebrow}</span>
    <h1 class="ct-title">
      <span class="ct-title-a">{COPY.title_a}</span>
      <span class="ct-title-b"><em>{COPY.title_b}</em></span>
      <span class="ct-title-c">{COPY.title_c}</span>
      <span class="ct-title-d">{COPY.title_d}</span>
    </h1>
    <p class="ct-lede">{COPY.lede}</p>
  </header>

  <!-- Channels grid -->
  <ol class="ct-cards" aria-label="Channels">
    {COPY.cards.map((c) => (
      <li class="ct-card">
        <a href={c.href} class="ct-card-link" target={c.external ? '_blank' : undefined} rel={c.external ? 'noopener' : undefined}>
          <span class="ct-card-n mono">{c.n}</span>
          <span class="ct-card-kicker mono">{c.kicker}</span>
          <h2 class="ct-card-title">{c.title}<span class="ct-card-dot">.</span></h2>
          <p class="ct-card-desc">{c.desc}</p>
          <span class="ct-card-cta">
            <span class="ct-arr">→</span>
            {c.cta}
          </span>
        </a>
      </li>
    ))}
  </ol>

  <!-- Socials strip -->
  <div class="ct-socials">
    <span class="ct-socials-eyebrow mono">{COPY.socials_eyebrow}</span>
    <ul class="ct-socials-list">
      {COPY.socials.map((s) => (
        <li>
          <a href={s.href} target="_blank" rel="noopener">
            <span class="ct-socials-name">{s.name}</span>
            <span class="ct-socials-handle mono">{s.handle}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- Office + specialised CTAs -->
  <div class="ct-office">
    <div class="ct-office-info">
      <span class="ct-office-eyebrow mono">{COPY.office_eyebrow}</span>
      <p class="ct-office-name">{COPY.office_title}</p>
      <p class="ct-office-line">{COPY.office_address}</p>
      <p class="ct-office-line mono">{COPY.office_cif}</p>
      <p class="ct-office-line mono">{COPY.office_coords}</p>
    </div>

    <div class="ct-tracks">
      <a class="ct-track" href={COPY.press_href}>
        <span class="ct-track-label mono">{COPY.press_label}</span>
        <span class="ct-track-lede">{COPY.press_lede}</span>
        <span class="ct-track-cta"><span class="ct-arr">→</span> {COPY.press_cta}</span>
      </a>
      <a class="ct-track" href={COPY.work_href}>
        <span class="ct-track-label mono">{COPY.work_label}</span>
        <span class="ct-track-lede">{COPY.work_lede}</span>
        <span class="ct-track-cta"><span class="ct-arr">→</span> {COPY.work_cta}</span>
      </a>
    </div>
  </div>
</section>
