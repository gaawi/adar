---
import type { Lang } from '../i18n/strings.ts';
import { HOME_SLUG, LANGS } from '../i18n/strings.ts';
import menusJson from '../content/_menus.json';

interface MenuItem {
  title: string;
  url: string;
  order: number;
  parent_id: number;
  item_id: number;
  classes?: string;
  children?: MenuItem[];
}

interface Props {
  lang: Lang;
  currentPath?: string;
  translations?: Partial<Record<Lang, string>>;
}

const { lang, currentPath = '', translations = {} } = Astro.props;

const menuKey = lang;
const flat: MenuItem[] = (menusJson as Record<string, MenuItem[]>)[menuKey] ?? [];

function localizeUrl(url: string): string {
  return url.replace(/^https?:\/\/festivaladar\.com/, '').replace(/^\/+/, '/');
}

// Top-level items only, ordered. Children attached.
const tops = flat
  .filter((m) => !m.parent_id)
  .sort((a, b) => a.order - b.order)
  .map((parent) => ({
    ...parent,
    children: flat
      .filter((c) => c.parent_id === parent.item_id)
      .filter((c) => c.url !== parent.url) // skip duplicate "Equipo > Equipo"
      .sort((a, b) => a.order - b.order),
  }));

// Status bar copy per language
const statusCopy = {
  es: { left: 'Festival ADAR · Principado de Asturias', right: 'Asturias · España · Europa' },
  en: { left: 'Festival ADAR · Principality of Asturias', right: 'Asturias · Spain · Europe' },
  ast: { left: 'Festival ADAR · Principáu d’Asturies', right: 'Asturies · España · Europa' },
}[lang];

const ctaLabel = { es: 'Newsletter', en: 'Newsletter', ast: 'Boletín' }[lang];
const ctaSubject = {
  es: 'Suscripción al boletín Festival ADAR',
  en: 'Festival ADAR newsletter subscription',
  ast: 'Suscripción al boletín Festival ADAR',
}[lang];
const ctaBody = {
  es: 'Hola, me gustaría recibir el programa de la próxima edición del Festival ADAR.',
  en: 'Hello, I would like to receive the programme for the next edition of Festival ADAR.',
  ast: 'Hola, prestaríame recibir el programa de la próxima edición del Festival ADAR.',
}[lang];
const ctaHref = `mailto:leiguardamusic@gmail.com?subject=${encodeURIComponent(ctaSubject)}&body=${encodeURIComponent(ctaBody)}`;

const homeHref = `/${lang}/${HOME_SLUG[lang]}/`;
---

<header id="masthead" class="site-header cd-header" role="banner">
  <div class="cd-status">
    <div class="cdcontainer cd-status-inner">
      <span><span class="cd-status-dot"></span>{statusCopy.left}</span>
      <span class="cd-status-region">{statusCopy.right}</span>
    </div>
  </div>

  <div class="cdcontainer cd-main">
    <a href={homeHref} class="cd-mark" rel="home" aria-label="Festival ADAR">
      <img
        class="cd-mark-logo"
        src="/logos/adar.png"
        alt="Festival ADAR"
        width="200"
        height="56"
      />
    </a>

    <nav class="cd-nav" aria-label="Primary">
      {tops.map((item, i) => {
        const href = localizeUrl(item.url);
        const hasChildren = (item.children?.length ?? 0) > 0;
        return (
          <div class={`cd-nav-item${hasChildren ? ' has-children' : ''}`}>
            <a href={href} class={href === currentPath ? 'is-current' : ''}>
              <span class="cd-nav-num">0{i + 1}</span>
              {item.title}
              {hasChildren && <span class="cd-nav-chev" aria-hidden="true">›</span>}
            </a>
            {hasChildren && (
              <div class="cd-submenu" role="menu">
                <ul>
                  {item.children!.map((sub) => (
                    <li>
                      <a href={localizeUrl(sub.url)} class={localizeUrl(sub.url) === currentPath ? 'is-current' : ''}>
                        {sub.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        );
      })}
    </nav>

    <div class="cd-right">
      <div class="cd-lang" aria-label="Language">
        {LANGS.map((l) => {
          const href = translations[l] || `/${l}/${HOME_SLUG[l]}/`;
          return (
            <a class={l === lang ? 'is-active' : ''} href={href} hreflang={l}>
              {l.toUpperCase()}
            </a>
          );
        })}
      </div>
      <a class="cd-cta" href={ctaHref}>{ctaLabel}</a>

      <button
        type="button"
        class="adar-nav-toggle"
        aria-label="Open menu"
        aria-controls="primary-nav"
        aria-expanded="false"
        data-nav-toggle
      >
        <span class="adar-nav-toggle-bar"></span>
        <span class="adar-nav-toggle-bar"></span>
        <span class="adar-nav-toggle-bar"></span>
      </button>
    </div>
  </div>

  <div class="header-navigation-wrapper" id="primary-nav">
    <nav class="primary-menu-wrapper" aria-label="Mobile" role="navigation">
      <ul class="nav navbar-nav">
        {tops.map((item, i) => (
          <li class="menu-item">
            <a href={localizeUrl(item.url)}>
              <span class="cd-nav-num">0{i + 1}</span> {item.title}
            </a>
            {(item.children?.length ?? 0) > 0 && (
              <ul class="sub-menu">
                {item.children!.map((sub) => (
                  <li><a href={localizeUrl(sub.url)}>{sub.title}</a></li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
      <div class="adar-header-lang">
        {LANGS.map((l) => {
          const href = translations[l] || `/${l}/${HOME_SLUG[l]}/`;
          return (
            <a class={`adar-header-lang-link ${l === lang ? 'is-active' : ''}`} href={href} hreflang={l}>
              {l.toUpperCase()}
            </a>
          );
        })}
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    const toggle = document.querySelector('[data-nav-toggle]');
    const nav = document.getElementById('primary-nav');
    if (!toggle || !nav) return;
    toggle.addEventListener('click', function () {
      const open = nav.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      document.body.classList.toggle('adar-nav-open', open);
    });
    nav.addEventListener('click', function (e) {
      if (e.target instanceof HTMLAnchorElement) {
        nav.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
        document.body.classList.remove('adar-nav-open');
      }
    });
  })();
</script>
