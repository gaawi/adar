---
import type { Lang } from '../i18n/strings.ts';
import { HOME_SLUG } from '../i18n/strings.ts';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const copy = {
  es: {
    desc: 'Festival ADAR es un proyecto de la Asociación para el Desarrollo de las Artes en el Medio Rural.',
    base: 'Sede: Leiguarda 47 · Belmonte de Miranda · Asturias · CIF G06781884',
    contact: 'Contacto',
    funded: 'Con el apoyo de',
    partners: 'Red de colaboración',
  },
  en: {
    desc: 'Festival ADAR is a project of the Association for the Development of Arts in the Rural Environment.',
    base: 'Headquarters: Leiguarda 47 · Belmonte de Miranda · Asturias · CIF G06781884',
    contact: 'Contact',
    funded: 'With the support of',
    partners: 'Network of partners',
  },
  ast: {
    desc: "Festival ADAR ye un proxectu de l'Asociación pal Desarrollu de les Artes nel Mediu Rural.",
    base: 'Sede: Leiguarda 47 · Belmonte de Miranda · Asturies · CIF G06781884',
    contact: 'Contautu',
    funded: 'Col sofitu de',
    partners: 'Rede de collaboración',
  },
}[lang];

const PARTNERS = [
  { name: 'CreArtBox', logo: '/logos/creartbox.jpg', href: 'https://creartbox.nyc/' },
  { name: 'Porto PianoFest', logo: '/logos/portopiano.jpg', href: 'https://www.portopianofest.com/' },
  { name: 'Opus 71 Concerts', logo: '/logos/opus71.jpg', href: 'https://www.opus71concerts.com/' },
  { name: 'Paris Chamber Music Circle', logo: '/logos/paris.jpg', href: '#' },
  { name: 'Asociación Musical Diego Silva Montero', logo: '/logos/diego-silva.jpg', href: '#' },
  { name: 'Ballarte Festival', logo: '/logos/ballarte.png', href: 'https://ballartefestival.benasque.com/' },
  { name: 'Paradores', logo: '/logos/paradores.jpg', href: 'https://paradores.es/' },
  { name: 'Caja Rural de Asturias', logo: '/logos/caja-rural.jpg', href: 'https://www.cajaruraldeasturias.com/' },
  { name: 'Escuela Reina Sofía', logo: '/logos/reina-sofia.jpg', href: 'https://www.escuelasuperiordemusicareinasofia.es/' },
];

const FUNDERS = [
  { name: 'European Commission', logo: '/logos/eu.png', href: 'https://european-union.europa.eu/' },
  { name: 'Goethe-Institut', logo: '/logos/goethe.png', href: 'https://www.goethe.de/' },
  { name: 'Principado de Asturias', logo: '/logos/asturias.png', href: 'https://www.asturias.es/' },
];
---

<footer class="adar-footer">
  <div class="adar-footer-divider" aria-hidden="true">
    <svg class="adar-footer-mountains" viewBox="0 0 1200 140" preserveAspectRatio="none" role="presentation">
      <path d="M0,110 L60,108 L90,105 L130,109 L170,100 L210,108 L260,96 L310,106 L350,95 L390,102 L430,90 L480,100 L520,92 L560,104 L600,88 L650,98 L700,92 L750,104 L800,95 L850,108 L900,98 L950,110 L1000,103 L1050,110 L1100,106 L1150,112 L1200,110 L1200,140 L0,140 Z"></path>
      <path class="front" d="M0,120 L40,115 L80,118 L120,110 L160,120 L200,102 L240,115 L280,95 L320,108 L360,98 L400,112 L440,90 L480,105 L520,92 L560,108 L600,86 L640,100 L680,92 L720,108 L760,95 L800,110 L840,100 L880,118 L920,104 L960,120 L1000,108 L1040,118 L1080,110 L1120,120 L1160,112 L1200,120 L1200,140 L0,140 Z"></path>
    </svg>
  </div>

  <div class="adar-footer-logos">
    <div class="adar-footer-logos-row adar-footer-logos-funders">
      <ul>
        {FUNDERS.map((f) => (
          <li>
            <a href={f.href} target="_blank" rel="noopener" aria-label={f.name}>
              <img src={f.logo} alt={f.name} loading="lazy" />
            </a>
          </li>
        ))}
      </ul>
    </div>
    <div class="adar-footer-logos-row adar-footer-logos-partners">
      <ul>
        {PARTNERS.map((p) => (
          <li>
            <a href={p.href} target="_blank" rel="noopener" aria-label={p.name}>
              <img src={p.logo} alt={p.name} loading="lazy" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="adar-footer-inner">
    <div class="adar-footer-col">
      <h3>Festival ADAR</h3>
      <p>{copy.desc}</p>
      <p class="adar-small">{copy.base}</p>

      <div class="adar-lang" aria-label="Language">
        <a class={`adar-lang-link ${lang === 'es' ? 'is-active' : ''}`} href={`/es/${HOME_SLUG.es}/`}>ES</a>
        <a class={`adar-lang-link ${lang === 'en' ? 'is-active' : ''}`} href={`/en/${HOME_SLUG.en}/`}>EN</a>
        <a class={`adar-lang-link ${lang === 'ast' ? 'is-active' : ''}`} href={`/ast/${HOME_SLUG.ast}/`}>AST</a>
      </div>
    </div>

    <div class="adar-footer-col">
      <h4>{copy.contact}</h4>
      <p>📧 leiguardamusic@gmail.com</p>
      <p>📱 WhatsApp: +34 663 60 40 30</p>

      <div class="adar-social">
        <a href="https://www.instagram.com/festivaladar" target="_blank" rel="noopener">Instagram</a>
        <a href="https://www.facebook.com/festivaladar" target="_blank" rel="noopener">Facebook</a>
        <a href="https://www.youtube.com/@festivaladar" target="_blank" rel="noopener">YouTube</a>
      </div>
    </div>

    <div class="adar-footer-col">
      <img class="adar-footer-mark" src="/logos/adar.png" alt="Festival ADAR" />
    </div>
  </div>

  <div class="adar-footer-bottom">© {new Date().getFullYear()} Festival ADAR</div>
</footer>
